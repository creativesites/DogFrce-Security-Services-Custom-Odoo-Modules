# Docker Compose project name — used as a prefix for container names.
COMPOSE_PROJECT_NAME=dogforce-odoo-dev

# Odoo Docker image tag. Default matches Odoo 19 Community.
ODOO_VERSION=19.0

# PostgreSQL connection settings (used by both db and odoo services).
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# Name of the Odoo application database to create and use locally.
ODOO_DB=dogforce_dev

# Odoo master password — required when creating databases via the web UI.
ODOO_ADMIN_PASSWORD=admin

# Host ports exposed by Docker Compose.
ODOO_PORT=8069
ODOO_LONGPOLLING_PORT=8072
