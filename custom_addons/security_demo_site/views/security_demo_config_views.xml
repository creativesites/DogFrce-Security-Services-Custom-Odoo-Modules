<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Demo Accounts list view -->
    <record id="security_demo_account_view_list" model="ir.ui.view">
        <field name="name">security.demo.account.view.list</field>
        <field name="model">security.demo.account</field>
        <field name="arch" type="xml">
            <list string="Demo Accounts" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="login"/>
                <field name="password_hint"/>
                <field name="description"/>
                <field name="user_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="security_demo_account_view_form" model="ir.ui.view">
        <field name="name">security.demo.account.view.form</field>
        <field name="model">security.demo.account</field>
        <field name="arch" type="xml">
            <form string="Demo Account">
                <sheet>
                    <group>
                        <group string="Display">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                        <group string="Credentials">
                            <field name="login"/>
                            <field name="password_hint"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="security_demo_account_action" model="ir.actions.act_window">
        <field name="name">Demo Accounts</field>
        <field name="res_model">security.demo.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Settings panel extension -->
    <record id="res_config_settings_view_demo_site" model="ir.ui.view">
        <field name="name">res.config.settings.view.security.demo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='general_settings']" position="before">
                <div class="app_settings_block" data-string="Demo Site" string="Demo Site"
                     data-key="security_demo_site" id="security_demo_site_settings">
                    <h2>Demo Site</h2>
                    <div class="row mt16 o_settings_container">

                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="demo_site_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="demo_site_enabled" class="o_form_label">Show Demo Panel</label>
                                <div class="text-muted">Display demo account credentials on the login page.</div>
                            </div>
                        </div>

                        <div class="col-xs-12 col-md-6 o_setting_box"
                             attrs="{'invisible': [('demo_site_enabled', '=', False)]}">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Panel Configuration</span>
                                <div class="content-group mt8">
                                    <div class="row">
                                        <label class="col-lg-4 o_light_label" for="demo_panel_title">Panel Title</label>
                                        <field name="demo_panel_title"/>
                                    </div>
                                    <div class="row mt4">
                                        <label class="col-lg-4 o_light_label" for="demo_redirect_action">Post-Login Redirect</label>
                                        <field name="demo_redirect_action"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Menu entry under Settings → Technical -->
    <menuitem id="menu_security_demo_accounts"
              name="Demo Accounts"
              parent="base.menu_administration"
              action="security_demo_account_action"
              sequence="50"/>
</odoo>
