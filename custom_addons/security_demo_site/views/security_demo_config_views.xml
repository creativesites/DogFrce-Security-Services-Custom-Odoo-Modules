<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Demo Accounts list view -->
    <record id="security_demo_account_view_list" model="ir.ui.view">
        <field name="name">security.demo.account.view.list</field>
        <field name="model">security.demo.account</field>
        <field name="arch" type="xml">
            <list string="Demo Accounts" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="login"/>
                <field name="password_hint"/>
                <field name="description"/>
                <field name="user_id"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="security_demo_account_view_form" model="ir.ui.view">
        <field name="name">security.demo.account.view.form</field>
        <field name="model">security.demo.account</field>
        <field name="arch" type="xml">
            <form string="Demo Account">
                <sheet>
                    <group>
                        <group string="Display">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="badge_color" widget="color"/>
                            <field name="description"/>
                        </group>
                        <group string="Credentials">
                            <field name="login"/>
                            <field name="password_hint"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group string="Feature Highlights">
                        <field name="features" nolabel="1" placeholder="One feature per line — shown as bullet points on the login panel"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="security_demo_account_action" model="ir.actions.act_window">
        <field name="name">Demo Accounts</field>
        <field name="res_model">security.demo.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Settings panel using Odoo 19 app/block/setting structure -->
    <record id="res_config_settings_view_demo_site" model="ir.ui.view">
        <field name="name">res.config.settings.view.security.demo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Demo Site"
                     string="Demo Site"
                     name="security_demo_site"
                     logo="/security_theme/static/src/img/deployguard.png">

                    <block title="Demo Login Panel" name="security_demo_panel_block">
                        <setting string="Show Demo Panel"
                                 help="Display demo account credentials on the login page.">
                            <field name="demo_site_enabled"/>
                        </setting>
                        <setting string="Panel Title"
                                 help="Heading shown above the demo accounts on the login page.">
                            <field name="demo_panel_title"/>
                        </setting>
                        <setting string="Post-Login Redirect"
                                 help="Where demo users land after logging in (e.g. /odoo/security-suite).">
                            <field name="demo_redirect_action"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <!-- Menu entry under Settings → Technical -->
    <menuitem id="menu_security_demo_accounts"
              name="Demo Accounts"
              parent="base.menu_administration"
              action="security_demo_account_action"
              sequence="50"/>
</odoo>
