<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- Category -->
        <record id="module_category_licensing" model="ir.module.category">
            <field name="name">DeployGuard Licensing</field>
            <field name="sequence">100</field>
        </record>

        <!-- Privilege (Odoo 19 intermediate layer) -->
        <record id="privilege_security_licensing" model="res.groups.privilege">
            <field name="name">DeployGuard Licensing</field>
            <field name="category_id" ref="module_category_licensing"/>
        </record>

        <!-- Groups -->
        <record id="group_license_admin" model="res.groups">
            <field name="name">License Administrator</field>
            <field name="privilege_id" ref="privilege_security_licensing"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Access: security.license — admins full, internal users read -->
        <record id="access_security_license_admin" model="ir.model.access">
            <field name="name">security.license admin</field>
            <field name="model_id" ref="model_security_license"/>
            <field name="group_id" ref="group_license_admin"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_security_license_user" model="ir.model.access">
            <field name="name">security.license user read</field>
            <field name="model_id" ref="model_security_license"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Access: security.license.log -->
        <record id="access_security_license_log_admin" model="ir.model.access">
            <field name="name">security.license.log admin</field>
            <field name="model_id" ref="model_security_license_log"/>
            <field name="group_id" ref="group_license_admin"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_security_license_log_user" model="ir.model.access">
            <field name="name">security.license.log user read</field>
            <field name="model_id" ref="model_security_license_log"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Access: license.key.wizard -->
        <record id="access_license_key_wizard" model="ir.model.access">
            <field name="name">license.key.wizard admin</field>
            <field name="model_id" ref="model_license_key_wizard"/>
            <field name="group_id" ref="group_license_admin"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
</odoo>
