<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Smart button on crm.lead form view -->
    <record id="crm_lead_view_form_inherit_security_billing" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.security.billing</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_security_contract"
                        string="Create Client Contract"
                        type="object"
                        class="btn-primary"
                        groups="security_base.group_security_supervisor"/>
                <button name="action_create_security_billing_plan"
                        string="Create Billing Plan"
                        type="object"
                        class="btn-secondary"
                        groups="security_base.group_security_supervisor"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_billing_plans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-usd"
                        groups="security_base.group_security_supervisor">
                    <field name="billing_plan_count" widget="statinfo" string="Billing Plans"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="billing_plan_ids" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Smart field on security.billing.plan form view -->
    <record id="view_security_billing_plan_form_inherit_crm" model="ir.ui.view">
        <field name="name">security.billing.plan.form.inherit.crm</field>
        <field name="model">security.billing.plan</field>
        <field name="inherit_id" ref="security_billing.view_security_billing_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="lead_id" groups="security_base.group_security_supervisor" readonly="1" invisible="not lead_id"/>
            </xpath>
        </field>
    </record>
</odoo>
