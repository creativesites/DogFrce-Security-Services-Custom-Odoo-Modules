<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_roster_generate_wizard_form" model="ir.ui.view">
        <field name="name">security.roster.generate.wizard.form</field>
        <field name="model">security.roster.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Monthly Roster">
                <group invisible="state != 'draft'">
                    <group string="Date Range">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group string="Options">
                        <field name="site_ids" widget="many2many_tags"/>
                        <field name="use_scoring_engine"/>
                    </group>
                </group>
                <group invisible="state != 'preview'" string="Preview">
                    <field name="batch_name" readonly="1"/>
                </group>
                <field name="preview_line_ids" invisible="state != 'preview'">
                    <list editable="bottom">
                        <field name="shift_date"/>
                        <field name="site_id" readonly="1"/>
                        <field name="post_id" readonly="1"/>
                        <field name="shift_template_id" readonly="1"/>
                        <field name="suggested_employee_id"/>
                    </list>
                </field>
                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_preview" type="object" string="Preview Roster"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" type="object" string="Confirm &amp; Create Roster"
                            class="btn-primary" invisible="state != 'preview'"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_security_roster_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Roster</field>
        <field name="res_model">security.roster.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
