<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="security_operations.OpsDashboard">
    <div class="od-root o_action">

        <!-- Loading -->
        <t t-if="state.loading">
            <div class="od-loading d-flex align-items-center justify-content-center py-5">
                <div class="spinner-border me-3" style="color: var(--df-navy);" role="status"/>
                <span class="fs-5 text-muted">Loading Operations Dashboard…</span>
            </div>
        </t>

        <t t-else="">
            <!-- Header -->
            <div class="od-header px-4 py-3 border-bottom bg-white d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <i class="fa fa-shield fs-3" style="color: var(--df-navy);"/>
                    <div>
                        <h4 class="mb-0 fw-bold" style="color: var(--df-navy);">Operations Dashboard</h4>
                        <small class="text-muted"><t t-esc="state.todayLabel"/></small>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" t-on-click="openLiveOps">
                        <i class="fa fa-eye me-1"/>Live Ops
                    </button>
                    <button class="btn btn-sm od-btn-navy" t-on-click="openRosterBoard">
                        <i class="fa fa-calendar me-1"/>Roster Board
                    </button>
                </div>
            </div>

            <!-- KPI Strip -->
            <div class="od-kpi-strip px-4 py-3 bg-white border-bottom">
                <div class="row g-3">
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2" style="color: var(--df-navy);">
                                <t t-esc="state.kpi.scheduled"/>
                            </div>
                            <div class="od-kpi-label text-muted small">Scheduled Today</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card od-kpi-present border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2 text-success">
                                <t t-esc="state.kpi.present"/>
                            </div>
                            <div class="od-kpi-label text-muted small">On Duty</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card od-kpi-warning border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2" style="color: #92600a;">
                                <t t-esc="state.kpi.late"/>
                            </div>
                            <div class="od-kpi-label text-muted small">Late Arrivals</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card od-kpi-danger border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2 text-danger">
                                <t t-esc="state.kpi.awol"/>
                            </div>
                            <div class="od-kpi-label text-muted small">AWOL</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2"
                                 t-att-class="state.kpi.criticalGaps > 0 ? 'text-danger' : 'text-success'">
                                <t t-esc="state.kpi.criticalGaps"/>
                            </div>
                            <div class="od-kpi-label text-muted small">Critical Gaps</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="od-kpi-card border rounded p-3 text-center h-100">
                            <div class="od-kpi-value fw-bold fs-2"
                                 t-att-class="statusClass(state.kpi.fillRate)">
                                <t t-esc="state.kpi.fillRate"/>%
                            </div>
                            <div class="od-kpi-label text-muted small">Fill Rate</div>
                            <div class="progress mt-1" style="height: 4px;">
                                <div class="progress-bar"
                                     t-att-class="barClass(state.kpi.fillRate)"
                                     t-att-style="'width: ' + state.kpi.fillRate + '%'"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main panels -->
            <div class="od-body px-4 py-3">
                <div class="row g-3">

                    <!-- AWOL Alerts -->
                    <div class="col-12 col-lg-6">
                        <div class="card shadow-sm" style="min-height: 280px;">
                            <div class="od-card-header d-flex align-items-center justify-content-between px-3 py-2">
                                <span>
                                    <i class="fa fa-exclamation-triangle me-1" style="color: var(--df-amber);"/>
                                    AWOL Alerts — Today
                                    <span class="badge ms-1 text-bg-danger" t-if="state.awolAlerts.length">
                                        <t t-esc="state.awolAlerts.length"/>
                                    </span>
                                </span>
                                <button class="btn btn-sm od-btn-amber"
                                        t-if="state.activeBatchId"
                                        t-att-disabled="state.filling"
                                        t-on-click="autoFillGaps">
                                    <t t-if="state.filling">
                                        <span class="spinner-border spinner-border-sm me-1" role="status"/>
                                        Filling…
                                    </t>
                                    <t t-else="">
                                        <i class="fa fa-magic me-1"/>Auto-Fill All Gaps
                                    </t>
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="!state.awolAlerts.length">
                                    <div class="text-center py-5 text-success">
                                        <i class="fa fa-check-circle fa-2x mb-2 d-block"/>
                                        <span>No AWOL incidents today</span>
                                    </div>
                                </t>
                                <t t-else="">
                                    <t t-foreach="state.awolAlerts" t-as="alert" t-key="alert.id">
                                        <div class="od-alert-row d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                            <div class="overflow-hidden me-2">
                                                <div class="fw-semibold small text-truncate">
                                                    <t t-esc="alert.employee_id ? alert.employee_id[1] : 'Unknown Guard'"/>
                                                </div>
                                                <div class="text-muted x-small">
                                                    <t t-if="alert.site_id"><t t-esc="alert.site_id[1]"/></t>
                                                    <t t-if="alert.post_id"><span class="mx-1">·</span><t t-esc="alert.post_id[1]"/></t>
                                                    <t t-if="alert.shift_template_id"><span class="mx-1">·</span><t t-esc="alert.shift_template_id[1]"/></t>
                                                </div>
                                            </div>
                                            <button class="btn btn-sm btn-outline-primary flex-shrink-0"
                                                    t-if="alert.roster_slot_id"
                                                    t-on-click="() => findReplacement(alert)">
                                                <i class="fa fa-exchange me-1"/>Find Replacement
                                            </button>
                                            <span class="badge text-bg-secondary flex-shrink-0" t-else="">
                                                No slot linked
                                            </span>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Sites Requiring Attention -->
                    <div class="col-12 col-lg-6">
                        <div class="card shadow-sm" style="min-height: 280px;">
                            <div class="od-card-header d-flex align-items-center justify-content-between px-3 py-2">
                                <span>
                                    <i class="fa fa-map-marker me-1" style="color: var(--df-amber);"/>
                                    Sites Requiring Attention
                                </span>
                                <button class="btn btn-sm btn-link text-white p-0 text-decoration-none"
                                        t-if="state.activeBatchId"
                                        t-on-click="openBatch">
                                    <small><t t-esc="state.activeBatchName"/><i class="fa fa-arrow-right ms-1"/></small>
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="!state.alertSites.length">
                                    <div class="text-center py-5 text-success">
                                        <i class="fa fa-check-circle fa-2x mb-2 d-block"/>
                                        <span>All sites fully staffed</span>
                                    </div>
                                </t>
                                <t t-else="">
                                    <t t-foreach="state.alertSites" t-as="site" t-key="site.id">
                                        <div class="od-site-row px-3 py-2 border-bottom">
                                            <div class="d-flex align-items-center justify-content-between mb-1">
                                                <span class="fw-semibold small"><t t-esc="site.name"/></span>
                                                <span class="small fw-bold" t-att-class="statusClass(site.fillRate)">
                                                    <t t-esc="site.fillRate"/>%
                                                </span>
                                            </div>
                                            <div class="progress mb-1" style="height: 5px;">
                                                <div class="progress-bar"
                                                     t-att-class="barClass(site.fillRate)"
                                                     t-att-style="'width: ' + site.fillRate + '%'"/>
                                            </div>
                                            <div class="d-flex gap-2 align-items-center">
                                                <span class="badge text-bg-danger x-small" t-if="site.criticalGaps">
                                                    <i class="fa fa-warning me-1"/>
                                                    <t t-esc="site.criticalGaps"/> critical
                                                </span>
                                                <span class="text-muted x-small" t-if="site.unassigned">
                                                    <t t-esc="site.unassigned"/> unassigned
                                                </span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </div>
</t>

</templates>
