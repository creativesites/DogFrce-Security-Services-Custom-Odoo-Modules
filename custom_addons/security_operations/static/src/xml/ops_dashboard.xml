<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="security_operations.OpsDashboard" owl="1">
<div class="o_ops_dashboard od-shell">

    <!-- ═══════════════════════════════════════════════════════════
         LEFT SIDEBAR — Control & Site Filters
         ═══════════════════════════════════════════════════════════ -->
    <div class="od-nav-sidebar d-flex flex-column">

        <!-- Brand Header -->
        <div class="od-brand px-4 py-3">
            <div class="fw-bold" style="font-size:15px; color:#1e1b4b; letter-spacing:.3px;">
                <i class="fa fa-dashboard me-2" style="color:#2563eb;"/>DogForce Operations
            </div>
            <div style="font-size:11px; color:#64748b; margin-top:2px;">Shift &amp; Incident Control</div>
        </div>

        <!-- Site Filter -->
        <div class="px-3 pt-3 pb-2">
            <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#64748b; margin-bottom:6px;">
                Security Site
            </div>
            <select class="form-select form-select-sm od-select" t-on-change="onSiteFilterChange">
                <option value="all">All Sites</option>
                <t t-if="state.data and state.data.sites" t-foreach="state.data.sites" t-as="s" t-key="s.id">
                    <option t-att-value="s.id" t-esc="s.name"/>
                </t>
            </select>
        </div>

        <!-- Shift Filter -->
        <div class="px-3 pb-2">
            <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#64748b; margin-bottom:6px;">
                Shift Type
            </div>
            <select class="form-select form-select-sm od-select" t-on-change="onShiftFilterChange">
                <option value="all">All Shifts</option>
                <option value="day">Day Shift</option>
                <option value="night">Night Shift</option>
            </select>
        </div>

        <!-- Quick Action Buttons -->
        <div class="px-3 pb-3 d-flex flex-column gap-2 mt-2">
            <button class="btn btn-sm text-white w-100 fw-semibold" style="background:#2563eb; border-radius:8px;" t-att-disabled="state.filling" t-on-click="autoFillGaps">
                <t t-if="state.filling"><span class="spinner-border spinner-border-sm me-1"/>Filling Gaps...</t>
                <t t-else=""><i class="fa fa-magic me-1"/>Auto-Fill All Open Gaps</t>
            </button>
            <button class="btn btn-sm btn-outline-primary w-100 fw-semibold" style="border-radius:8px; font-size:12px;" t-on-click="openRosterBoard">
                <i class="fa fa-th me-1"/>Launch Roster Board
            </button>
            <button class="btn btn-sm btn-light w-100 text-muted" style="font-size:11px;" t-on-click="loadData">
                <i class="fa fa-refresh me-1"/>Refresh Live Data
            </button>
        </div>

        <div style="border-top:1px solid rgba(15, 23, 42, 0.08); margin:4px 0;"/>

        <!-- Shift Fill Rate Gauge -->
        <div t-if="state.data" class="px-3 py-3">
            <div style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:#64748b; margin-bottom:8px;">
                Daily Guard Fill Rate
            </div>
            <div class="d-flex align-items-center justify-content-between mb-1">
                <span class="fw-bold" style="font-size:18px; color:#1e1b4b;"><t t-esc="state.data.fill_rate_pct"/>%</span>
                <span class="small text-muted"><t t-esc="state.data.on_duty_count"/> / <t t-esc="state.data.total_scheduled"/> Guarded</span>
            </div>
            <div class="progress" style="height:7px; border-radius:4px; background:#e2e8f0;">
                <div class="progress-bar" t-att-style="'width:' + state.data.fill_rate_pct + '%; background:#2563eb;'"/>
            </div>
        </div>

    </div>


    <!-- ═══════════════════════════════════════════════════════════
         MAIN WORKSPACE — Header Strip + Main Content Area
         ═══════════════════════════════════════════════════════════ -->
    <div class="od-main">

        <!-- Top Header & KPI Strip -->
        <div class="od-header px-4 py-2 d-flex align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="input-group input-group-sm" style="width:240px;">
                    <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted"/></span>
                    <input type="text" class="form-control border-start-0 ps-0" placeholder="Search site, guard, post..." t-on-input="onSearchInput"/>
                </div>
            </div>

            <!-- KPI Cards Strip -->
            <div t-if="state.data" class="od-kpi-pills">
                <div class="od-kpi-card text-center">
                    <div class="text-muted x-small fw-semibold text-uppercase">Scheduled Today</div>
                    <div class="fs-5 fw-bold text-dark"><t t-esc="state.data.total_scheduled"/></div>
                </div>
                <div class="od-kpi-card text-center">
                    <div class="text-muted x-small fw-semibold text-uppercase">On Duty</div>
                    <div class="fs-5 fw-bold text-success"><t t-esc="state.data.on_duty_count"/></div>
                </div>
                <div class="od-kpi-card text-center">
                    <div class="text-muted x-small fw-semibold text-uppercase">Critical Open Gaps</div>
                    <div t-att-class="'fs-5 fw-bold ' + (state.data.open_gaps_count > 0 ? 'text-danger' : 'text-muted')">
                        <t t-esc="state.data.open_gaps_count"/>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Workspace Area with Inspector -->
        <div t-att-class="'od-workspace ' + (state.selectedAlert || state.selectedSite ? 'has-inspector' : '')">

            <!-- Content Area -->
            <div class="od-content-area">

                <!-- Loading State -->
                <t t-if="state.loading">
                    <div class="d-flex align-items-center justify-content-center py-5 gap-3 text-muted">
                        <div class="spinner-border text-primary" role="status"/>
                        <span class="fs-5">Connecting Operations Command...</span>
                    </div>
                </t>

                <t t-else="">
                    <!-- SECTION 1: CRITICAL SHIFT GAPS & AWOL ALERTS -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                            <h6 class="mb-0 fw-bold text-danger"><i class="fa fa-exclamation-circle me-2"/>Unassigned Shift Gaps &amp; AWOL Alerts (<t t-esc="filteredAlerts.length"/>)</h6>
                            <button class="btn btn-xs btn-outline-primary" t-on-click="openLiveOps">Open Full Live Stream</button>
                        </div>
                        <div class="card-body p-0">
                            <div class="row g-0">
                                <t t-foreach="filteredAlerts" t-as="alert" t-key="alert.slot_id">
                                    <div class="col-12 col-md-6 border-bottom border-end p-3">
                                        <div t-att-class="'card od-card p-3 cursor-pointer ' + (state.selectedAlert and state.selectedAlert.slot_id === alert.slot_id ? 'od-card-active' : '')"
                                             t-on-click="() => this.selectAlert(alert)">
                                            <div class="d-flex align-items-start justify-content-between mb-1">
                                                <div>
                                                    <span class="fw-bold fs-6 text-dark"><t t-esc="alert.site"/></span>
                                                    <div class="text-muted small"><t t-esc="alert.post"/></div>
                                                </div>
                                                <span class="badge bg-danger text-white"><i class="fa fa-warning me-1"/>OPEN GAP</span>
                                            </div>

                                            <div class="d-flex align-items-center gap-3 my-2 text-secondary fs-7">
                                                <div><i class="fa fa-clock-o text-muted me-1"/>Start: <t t-esc="alert.start_time"/></div>
                                                <div><i class="fa fa-user me-1 text-danger"/><t t-esc="alert.guard"/></div>
                                            </div>

                                            <div class="d-flex align-items-center justify-content-between border-top pt-2 mt-1">
                                                <span class="x-small text-muted">Click to view replacement candidates</span>
                                                <button class="btn btn-xs btn-primary text-white" t-on-click.stop="() => this.selectAlert(alert)">
                                                    <i class="fa fa-user-plus me-1"/>Find Replacement
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="filteredAlerts.length === 0">
                                    <div class="col-12 text-center py-5 text-success">
                                        <i class="fa fa-check-circle fa-3x mb-2 d-block"/>
                                        <h5>All scheduled shifts are 100% manned! No open gaps.</h5>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- SECTION 2: SITES REQUIRING ATTENTION -->
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white py-3">
                            <h6 class="mb-0 fw-bold"><i class="fa fa-building me-2 text-primary"/>Security Client Sites &amp; Fill Rates</h6>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light fs-7">
                                    <tr>
                                        <th>Site Name</th>
                                        <th>Location</th>
                                        <th>Supervisor</th>
                                        <th class="text-center">Coverage</th>
                                        <th class="text-center">Open Gaps</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="filteredSites" t-as="site" t-key="site.site_id">
                                        <tr t-on-click="() => this.selectSite(site)" style="cursor:pointer;">
                                            <td class="fw-bold text-dark"><t t-esc="site.site"/></td>
                                            <td class="text-muted"><t t-esc="site.location"/></td>
                                            <td><t t-esc="site.supervisor"/></td>
                                            <td class="text-center">
                                                <span t-att-class="'fw-bold ' + (site.risk_level === 'critical' ? 'text-danger' : (site.risk_level === 'warning' ? 'text-warning' : 'text-success'))">
                                                    <t t-esc="site.fill_rate_pct"/>%
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <span t-att-class="'badge ' + (site.open_gaps > 0 ? 'bg-danger' : 'bg-light text-muted')">
                                                    <t t-esc="site.open_gaps"/> Gaps
                                                </span>
                                            </td>
                                            <td class="text-end" t-on-click.stop="">
                                                <button class="btn btn-xs btn-outline-secondary" t-on-click="() => this.openSiteForm(site.site_id)">
                                                    View Site
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>

            </div>

            <!-- ═══════════════════════════════════════════════════════════
                 RIGHT INSPECTOR PANEL — Shift Command Inspector Drawer
                 ═══════════════════════════════════════════════════════════ -->
            <div t-if="state.selectedAlert || state.selectedSite" class="od-inspector p-3">

                <!-- ALERT INSPECTOR WITH LIVE CANDIDATE PICKER -->
                <t t-if="state.selectedAlert">
                    <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                        <div>
                            <div class="fw-bold fs-6 text-dark"><t t-esc="state.selectedAlert.site"/></div>
                            <small class="text-muted"><t t-esc="state.selectedAlert.post"/></small>
                        </div>
                        <button class="btn-close" t-on-click="closeInspector"/>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <div class="p-3 bg-danger-subtle rounded-3 border border-danger-subtle">
                            <div class="text-danger x-small text-uppercase fw-bold mb-1">Shift Gap Context</div>
                            <div class="fs-7 text-dark">
                                <div><i class="fa fa-calendar me-2"/>Date: <t t-esc="state.selectedAlert.shift_date"/></div>
                                <div><i class="fa fa-clock-o me-2"/>Start Time: <t t-esc="state.selectedAlert.start_time"/></div>
                            </div>
                        </div>

                        <div>
                            <div class="fw-bold fs-7 text-dark mb-2"><i class="fa fa-magic text-primary me-1"/>Recommended Available Guards</div>

                            <t t-if="state.loadingSuggestions">
                                <div class="text-center py-3 text-muted"><div class="spinner-border spinner-border-sm me-1"/>Matching guards...</div>
                            </t>

                            <t t-else="">
                                <div class="d-flex flex-column gap-2">
                                    <t t-foreach="state.suggestions" t-as="cand" t-key="cand.id">
                                        <div class="border rounded p-2 d-flex align-items-center justify-content-between bg-white hover-shadow">
                                            <div>
                                                <div class="fw-bold text-dark fs-7"><t t-esc="cand.name"/></div>
                                                <div class="x-small text-muted"><i class="fa fa-phone me-1"/><t t-esc="cand.phone"/></div>
                                            </div>
                                            <button class="btn btn-xs btn-success text-white fw-bold" t-on-click="() => this.assignReplacement(state.selectedAlert.slot_id, cand.id)">
                                                Assign
                                            </button>
                                        </div>
                                    </t>
                                    <t t-if="state.suggestions.length === 0">
                                        <div class="text-muted small py-2 text-center">No available off-duty guards found for this date.</div>
                                    </t>
                                </div>
                            </t>
                        </div>

                        <button class="btn btn-sm btn-outline-secondary w-100 mt-2" t-on-click="() => this.openSlotForm(state.selectedAlert.slot_id)">
                            Open Slot Form
                        </button>
                    </div>
                </t>

                <!-- SITE INSPECTOR -->
                <t t-if="state.selectedSite">
                    <div class="d-flex align-items-center justify-content-between border-bottom pb-2 mb-3">
                        <div>
                            <div class="fw-bold fs-6 text-dark"><t t-esc="state.selectedSite.site"/></div>
                            <small class="text-muted"><t t-esc="state.selectedSite.location"/></small>
                        </div>
                        <button class="btn-close" t-on-click="closeInspector"/>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <div class="border rounded p-2 fs-7">
                            <div class="d-flex justify-content-between py-1 border-bottom">
                                <span class="text-muted">Supervisor</span>
                                <span class="fw-bold"><t t-esc="state.selectedSite.supervisor"/></span>
                            </div>
                            <div class="d-flex justify-content-between py-1 border-bottom">
                                <span class="text-muted">Total Posts Required</span>
                                <span class="fw-bold"><t t-esc="state.selectedSite.total_required"/></span>
                            </div>
                            <div class="d-flex justify-content-between py-1 border-bottom">
                                <span class="text-muted">Guards Assigned</span>
                                <span class="fw-bold text-success"><t t-esc="state.selectedSite.assigned"/></span>
                            </div>
                            <div class="d-flex justify-content-between py-1">
                                <span class="text-muted">Open Gaps</span>
                                <span class="fw-bold text-danger"><t t-esc="state.selectedSite.open_gaps"/></span>
                            </div>
                        </div>

                        <button class="btn btn-sm btn-outline-primary w-100 mt-2" t-on-click="() => this.openSiteForm(state.selectedSite.site_id)">
                            Open Security Site Form
                        </button>
                    </div>
                </t>

            </div>

        </div>

    </div>

</div>
</t>

</templates>
