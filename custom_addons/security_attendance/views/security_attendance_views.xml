<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_attendance_record_list" model="ir.ui.view">
        <field name="name">security.attendance.record.list</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <list decoration-danger="missing_check_out or status == 'absent'" decoration-warning="late_minutes > 0 or early_departure_minutes > 0" decoration-success="status == 'present' and late_minutes == 0 and early_departure_minutes == 0">
                <field name="shift_date"/>
                <field name="partner_id"/>
                <field name="site_id"/>
                <field name="employee_id"/>
                <field name="post_id"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="late_minutes" optional="show"/>
                <field name="early_departure_minutes" optional="hide"/>
                <field name="billing_amount" optional="hide" widget="monetary"/>
                <field name="has_billing_exception" optional="hide" widget="boolean_toggle"/>
                <field name="billing_approved" optional="hide" widget="boolean_toggle"/>
                <field name="missing_check_out" column_invisible="1"/>
                <field name="status" widget="badge" decoration-danger="status == 'absent'" decoration-success="status == 'present'"/>
            </list>
        </field>
    </record>

    <record id="view_security_attendance_record_search" model="ir.ui.view">
        <field name="name">security.attendance.record.search</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="site_id"/>
                <field name="shift_date"/>
                <filter name="filter_late" string="Late Arrivals" domain="[('late_minutes', '>', 0)]"/>
                <filter name="filter_missing_checkout" string="Missing Check-Out" domain="[('missing_check_out', '=', True)]"/>
                <filter name="filter_absent" string="Absent" domain="[('status', '=', 'absent')]"/>
                <separator/>
                <filter name="filter_billing_exceptions" string="Billing Exceptions" domain="[('has_billing_exception', '=', True)]"/>
                <filter name="filter_pending_approval" string="Pending Approval" domain="[('has_billing_exception', '=', True), ('billing_approved', '=', False)]"/>
                <filter name="filter_billing_approved" string="Billing Approved" domain="[('billing_approved', '=', True)]"/>
                <separator/>
                <filter name="group_date" string="Group by Date" context="{'group_by': 'shift_date'}"/>
                <filter name="group_employee" string="Group by Guard" context="{'group_by': 'employee_id'}"/>
                <filter name="group_site" string="Group by Site" context="{'group_by': 'site_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_security_attendance_record_form" model="ir.ui.view">
        <field name="name">security.attendance.record.form</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="shift_date" readonly="1"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="roster_slot_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="site_id" readonly="1"/>
                            <field name="post_id" readonly="1"/>
                            <field name="shift_template_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="status" readonly="1" widget="badge" decoration-danger="status == 'absent'" decoration-success="status == 'present'"/>
                            <field name="missing_check_out" readonly="1" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Time Calculation">
                        <group>
                            <field name="scheduled_start" readonly="1"/>
                            <field name="scheduled_end" readonly="1"/>
                            <field name="scheduled_hours" readonly="1"/>
                        </group>
                        <group>
                            <field name="worked_hours" readonly="1"/>
                            <field name="valid_hours" readonly="1"/>
                            <field name="late_minutes" readonly="1"/>
                            <field name="early_departure_minutes" readonly="1"/>
                        </group>
                    </group>
                    <group string="Billing">
                        <group>
                            <field name="billing_contract_id" readonly="1"/>
                            <field name="billing_amount" readonly="1" widget="monetary"/>
                        </group>
                        <group>
                            <field name="payable_hours" readonly="1"/>
                            <field name="overtime_hours" readonly="1"/>
                            <field name="overtime_approved" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Billing Approval" invisible="not has_billing_exception">
                        <group>
                            <field name="has_billing_exception" readonly="1" widget="boolean_toggle"/>
                            <field name="billing_exception_reason" readonly="1"/>
                        </group>
                        <group>
                            <field name="billing_approved" widget="boolean_toggle"/>
                            <field name="billing_approved_by_id" readonly="1"/>
                            <field name="billing_approved_date" readonly="1"/>
                        </group>
                    </group>
                    <div class="text-center mb-3" invisible="not has_billing_exception or billing_approved">
                        <button name="action_approve_billing" type="object"
                                string="Approve for Billing" class="btn btn-success"/>
                        <p class="text-muted small mt-1">
                            This record has exceptions. Review and approve to include it in invoice generation.
                        </p>
                    </div>
                    <div class="text-center mb-3" invisible="not billing_approved">
                        <button name="action_reset_billing_approval" type="object"
                                string="Reset Approval" class="btn btn-secondary btn-sm"/>
                    </div>
                    <group string="Supervisor Adjustments">
                        <field name="override_reason" placeholder="If modifying check-in/out manually, provide a reason..."/>
                        <field name="note" placeholder="General notes about this attendance record..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_security_attendance_record_pivot" model="ir.ui.view">
        <field name="name">security.attendance.record.pivot</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <pivot string="Attendance Analysis">
                <field name="site_id" type="row"/>
                <field name="shift_date" type="col"/>
                <field name="worked_hours" type="measure"/>
                <field name="late_minutes" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_security_attendance_record_graph" model="ir.ui.view">
        <field name="name">security.attendance.record.graph</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <graph string="Attendance Trend" type="bar">
                <field name="site_id"/>
                <field name="worked_hours" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_security_attendance_record" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">security.attendance.record</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_security_attendance_record_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first Attendance!
            </p>
            <p>
                Attendance records track when guards clock in and out, comparing it to their scheduled Roster Slots.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_security_attendance_record"
        name="Attendance Records"
        parent="security_operations.menu_security_workforce"
        action="action_security_attendance_record"
        sequence="10"
        groups="hr.group_hr_user"
    />

    <!-- Billing Exception Queue -->

    <record id="view_billing_exception_queue_list" model="ir.ui.view">
        <field name="name">security.attendance.record.exception.list</field>
        <field name="model">security.attendance.record</field>
        <field name="arch" type="xml">
            <list decoration-danger="not billing_approved" decoration-success="billing_approved"
                  string="Billing Exception Queue">
                <field name="shift_date"/>
                <field name="employee_id"/>
                <field name="site_id"/>
                <field name="billing_exception_reason"/>
                <field name="billing_amount" widget="monetary"/>
                <field name="billing_approved" widget="boolean_toggle"/>
                <field name="billing_approved_by_id"/>
                <field name="billing_approved_date"/>
                <field name="status" widget="badge"
                       decoration-danger="status == 'absent'"
                       decoration-warning="status in ('late', 'early_leave')"
                       decoration-success="status == 'present'"/>
            </list>
        </field>
    </record>

    <record id="action_billing_exception_queue" model="ir.actions.act_window">
        <field name="name">Billing Exception Queue</field>
        <field name="res_model">security.attendance.record</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_billing_exception_queue_list"/>
        <field name="domain">[('has_billing_exception', '=', True)]</field>
        <field name="context">{'search_default_filter_pending_approval': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No billing exceptions!</p>
            <p>All attendance records are clean. Exceptions appear here when guards are late,
               absent, AWOL, have missing check-outs, or have unapproved overtime.</p>
        </field>
    </record>

    <record id="action_bulk_approve_billing" model="ir.actions.server">
        <field name="name">Approve for Billing</field>
        <field name="model_id" ref="security_attendance.model_security_attendance_record"/>
        <field name="binding_model_id" ref="security_attendance.model_security_attendance_record"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_approve_billing()</field>
    </record>

    <record id="action_bulk_reset_billing_approval" model="ir.actions.server">
        <field name="name">Reset Billing Approval</field>
        <field name="model_id" ref="security_attendance.model_security_attendance_record"/>
        <field name="binding_model_id" ref="security_attendance.model_security_attendance_record"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_reset_billing_approval()</field>
    </record>

    <menuitem
        id="menu_billing_exception_queue"
        name="Billing Exception Queue"
        parent="security_operations.menu_security_billing_root"
        action="action_billing_exception_queue"
        sequence="3"
        groups="hr.group_hr_user"
    />
</odoo>
