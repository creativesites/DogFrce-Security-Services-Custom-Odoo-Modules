<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
<t t-name="security_notifications.NotificationBell">
    <div style="position:relative; display:flex; align-items:center; padding:0 8px; cursor:pointer;"
         t-on-click="() => this.toggleDropdown()">

        <!-- Bell icon with badge -->
        <div style="position:relative;">
            <i class="fa fa-bell fa-lg" t-att-style="'color:' + bellColor + ';'"/>
            <t t-if="state.unreadCount > 0">
                <span style="position:absolute;top:-6px;right:-8px;background:#dc2626;color:white;border-radius:10px;padding:1px 5px;font-size:10px;font-weight:700;min-width:16px;text-align:center;line-height:14px;">
                    <t t-esc="state.unreadCount > 99 ? '99+' : state.unreadCount"/>
                </span>
            </t>
        </div>

        <!-- Dropdown -->
        <t t-if="state.open">
            <div style="position:absolute;top:100%;right:0;width:360px;background:white;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.15);z-index:9999;border:1px solid #e2e8f0;overflow:hidden;"
                 t-on-click.stop="">
                <!-- Header -->
                <div style="padding:12px 16px;background:#1e3a5f;display:flex;align-items:center;justify-content:space-between;">
                    <span style="color:white;font-weight:600;font-size:14px;">
                        <i class="fa fa-bell me-2"/>Notifications
                        <t t-if="state.unreadCount > 0">
                            (<t t-esc="state.unreadCount"/>)
                        </t>
                    </span>
                    <button style="background:rgba(255,255,255,0.15);border:none;color:white;border-radius:6px;padding:3px 8px;font-size:11px;cursor:pointer;"
                            t-on-click="() => this.markAllRead()">
                        Mark all read
                    </button>
                </div>

                <!-- Notification list -->
                <div style="max-height:320px;overflow-y:auto;">
                    <t t-if="state.notifications.length === 0">
                        <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                            <i class="fa fa-check-circle fa-2x" style="color:#16a34a;display:block;margin-bottom:8px;"/>
                            All caught up!
                        </div>
                    </t>
                    <t t-foreach="state.notifications" t-as="notif" t-key="notif.id">
                        <div style="padding:12px 16px;border-bottom:1px solid #f1f5f9;display:flex;gap:10px;align-items:flex-start;">
                            <span t-att-style="'width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:5px;background:' + (notif.severity === 'critical' ? '#dc2626' : notif.severity === 'warning' ? '#d97706' : '#2563eb') + ';'"/>
                            <div style="flex:1;min-width:0;">
                                <div style="font-weight:600;font-size:13px;color:#1e293b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    <t t-esc="notif.title"/>
                                </div>
                                <div style="font-size:12px;color:#64748b;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    <t t-esc="notif.body || ''"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Footer -->
                <div style="padding:10px 16px;border-top:1px solid #e2e8f0;text-align:center;">
                    <button style="background:none;border:none;color:#2563eb;font-size:12px;cursor:pointer;font-weight:600;"
                            t-on-click="() => this.openNotifications()">
                        View all notifications &#x2192;
                    </button>
                </div>
            </div>
        </t>
    </div>
</t>
</templates>
