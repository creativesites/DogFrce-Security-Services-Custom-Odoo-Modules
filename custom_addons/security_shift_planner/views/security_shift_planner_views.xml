<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject suggestion button + tab into roster slot form -->
    <record id="view_security_roster_slot_form_planner" model="ir.ui.view">
        <field name="name">security.roster.slot.form.planner</field>
        <field name="model">security.roster.slot</field>
        <field name="inherit_id" ref="security_operations.view_security_roster_slot_form"/>
        <field name="arch" type="xml">
            <!-- Add Suggest Guards button before the statusbar -->
            <xpath expr="//header/field[@name='state']" position="before">
                <button name="action_suggest_guards" type="object"
                        string="Suggest Guards" icon="fa-magic"
                        invisible="employee_id != False"/>
            </xpath>
            <!-- Suggestions panel injected before the first group in the sheet -->
            <xpath expr="//sheet/group[1]" position="before">
                <div class="alert alert-info mb-3" invisible="suggestion_count == 0">
                    <strong><i class="fa fa-magic me-1"/>Top Guard Suggestions</strong>
                    <field name="suggestion_ids" nolabel="1">
                        <list>
                            <field name="rank" string="#" width="40px"/>
                            <field name="employee_id"/>
                            <field name="employee_grade_id" string="Grade"/>
                            <field name="score" string="Score" digits="[6,1]"/>
                            <field name="score_breakdown" string="Reasoning"/>
                            <button name="action_assign_to_slot" type="object"
                                    string="Assign" class="btn-sm btn-primary"
                                    icon="fa-check"/>
                        </list>
                    </field>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
