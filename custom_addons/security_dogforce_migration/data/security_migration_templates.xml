<odoo noupdate="1">

    <!--
        CSV Import Templates
        Each record stores the column-header row (plus one example row) as base64-encoded text.
        Users can download these attachments from the Settings > Technical > Attachments menu,
        fill them in, and upload via the Migration Job form.

        Base64 values were generated from plain UTF-8 CSV strings:

          guards:
            name,work_email,mobile_phone,grade_code,ssc_number,tax_number,bank_name,bank_account_number
            John Doe,john@dogforce.na,+264811234567,G1,SSC-001,TAX-001,Bank Windhoek,2100000123

          clients:
            client_name,client_email,site_name,site_code,site_location
            Windhoek Mall,info@dogforce.na,Main Entrance,WMALL-01,Windhoek City Centre

          leave_balances:
            employee_name_or_email,leave_type_name,balance_days,year
            John Doe,Annual Leave,15.0,2026

          loans:
            employee_name_or_email,principal_amount,repayment_months,start_date,note
            John Doe,5000.00,12,2026-06-01,Emergency loan
    -->

