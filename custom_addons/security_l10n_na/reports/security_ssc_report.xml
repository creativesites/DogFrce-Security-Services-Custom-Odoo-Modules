<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================= -->
    <!-- Social Security Commission Monthly Return — QWeb PDF     -->
    <!-- Model: security.payroll.period                           -->
    <!-- ======================================================= -->

    <template id="report_security_ssc_submission_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="period">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px;">

                        <!-- Title block -->
                        <div style="text-align: center; margin-bottom: 16px;">
                            <h2 style="margin: 0; text-transform: uppercase; letter-spacing: 1px;">
                                Social Security Commission
                            </h2>
                            <h3 style="margin: 4px 0 0 0;">
                                Monthly Return — Employer Contribution Schedule
                            </h3>
                        </div>

                        <!-- Header info box -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;" border="1">
                            <tr>
                                <td style="padding: 4px 8px; width: 25%;"><strong>Company Name</strong></td>
                                <td style="padding: 4px 8px;" colspan="3">
                                    <t t-esc="env.company.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 8px;"><strong>Registration Number</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="env.company.company_registry or env.company.vat or 'N/A'"/>
                                </td>
                                <td style="padding: 4px 8px; width: 20%;"><strong>Period</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="period.date_from and period.date_from.strftime('%B %Y') or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 8px;"><strong>Submission Date</strong></td>
                                <td style="padding: 4px 8px;" colspan="3">
                                    <t t-esc="period.date_to"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Employee SSC schedule table -->
                        <t t-set="active_slips" t-value="period.payslip_ids.filtered(lambda p: p.state in ('confirmed', 'paid'))"/>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;" border="1">
                            <thead>
                                <tr style="background-color: #006633; color: white;">
                                    <th style="padding: 5px 6px; text-align: center; width: 4%;">#</th>
                                    <th style="padding: 5px 6px; text-align: left; width: 22%;">Employee Name</th>
                                    <th style="padding: 5px 6px; text-align: left; width: 16%;">SSC Number</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 15%;">Gross Wages (NAD)</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 14%;">Employee SSC</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 14%;">Employer SSC</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 15%;">Total SSC</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="active_slips" t-as="slip">
                                    <t t-set="ssc_lines" t-value="slip.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc')"/>
                                    <t t-set="employee_ssc" t-value="sum(ssc_lines.mapped('amount'))"/>
                                    <t t-set="employer_ssc" t-value="employee_ssc"/>
                                    <t t-set="total_ssc" t-value="employee_ssc + employer_ssc"/>
                                    <tr>
                                        <td style="padding: 4px 6px; text-align: center;">
                                            <t t-esc="slip_index + 1"/>
                                        </td>
                                        <td style="padding: 4px 6px;">
                                            <t t-esc="slip.employee_id.name"/>
                                        </td>
                                        <td style="padding: 4px 6px;">
                                            <t t-esc="slip.employee_id.security_ssc_number or '—'"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % slip.total_earnings"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % employee_ssc"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % employer_ssc"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % total_ssc"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #e8e8e8; font-weight: bold;">
                                    <td style="padding: 5px 6px; text-align: right;" colspan="3">TOTALS</td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(active_slips.mapped('total_earnings'))"/>
                                    </td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(
                                            sum(s.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc').mapped('amount'))
                                            for s in active_slips
                                        )"/>
                                    </td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(
                                            sum(s.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc').mapped('amount'))
                                            for s in active_slips
                                        )"/>
                                    </td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % (2 * sum(
                                            sum(s.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc').mapped('amount'))
                                            for s in active_slips
                                        ))"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Declaration / signature block -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 24px;" border="0">
                            <tr>
                                <td style="width: 50%; padding-right: 16px; vertical-align: top;">
                                    <p style="margin: 0; font-size: 10px; color: #555;">
                                        I, the undersigned employer or authorised representative, hereby confirm
                                        that the above information is accurate and that the contributions
                                        reflected will be remitted in full.
                                    </p>
                                    <br/>
                                    <p style="margin: 0;">Authorised Signatory: ________________________</p>
                                    <p style="margin: 4px 0 0 0;">Date: ________________________</p>
                                </td>
                                <td style="width: 50%; padding-left: 16px; vertical-align: top; font-size: 10px; color: #555;">
                                    <p style="margin: 0; font-style: italic;">
                                        Submitted in accordance with the Social Security Act 34 of 1994.<br/>
                                        Deadline: 20th of the following month.<br/>
                                        Late payment attracts a penalty of 10% plus interest.
                                    </p>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report action -->
    <record id="action_report_security_ssc_submission" model="ir.actions.report">
        <field name="name">SSC Monthly Return</field>
        <field name="model">security.payroll.period</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_l10n_na.report_security_ssc_submission_document</field>
        <field name="report_file">security_l10n_na.report_security_ssc_submission_document</field>
        <field name="print_report_name">'SSC_Monthly_Return_%s' % (object.name or 'Schedule')</field>
        <field name="binding_type">report</field>
    </record>

</odoo>
