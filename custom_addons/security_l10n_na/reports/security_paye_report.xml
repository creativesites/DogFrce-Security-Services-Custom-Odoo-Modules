<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ======================================================= -->
    <!-- NamRA PAYE Submission Report — QWeb PDF                  -->
    <!-- Model: security.payroll.period                           -->
    <!-- ======================================================= -->

    <template id="report_security_paye_submission_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="period">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px;">

                        <!-- Title block -->
                        <div style="text-align: center; margin-bottom: 16px;">
                            <h2 style="margin: 0; text-transform: uppercase; letter-spacing: 1px;">
                                Namibia Revenue Agency
                            </h2>
                            <h3 style="margin: 4px 0 0 0;">
                                Employer's Tax Schedule (Monthly)
                            </h3>
                        </div>

                        <!-- Header info box -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;" border="1">
                            <tr>
                                <td style="padding: 4px 8px; width: 25%;"><strong>Tax Year</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="period.date_from and period.date_from.year or ''"/>
                                </td>
                                <td style="padding: 4px 8px; width: 25%;"><strong>Month</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="period.date_from and period.date_from.strftime('%B %Y') or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 8px;"><strong>Company Name</strong></td>
                                <td style="padding: 4px 8px;" colspan="3">
                                    <t t-esc="env.company.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px 8px;"><strong>Employer PAYE Reference</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="env.company.vat or 'N/A'"/>
                                </td>
                                <td style="padding: 4px 8px;"><strong>PAYE Period</strong></td>
                                <td style="padding: 4px 8px;">
                                    <t t-esc="period.date_from"/> — <t t-esc="period.date_to"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Employee schedule table -->
                        <t t-set="active_slips" t-value="period.payslip_ids.filtered(lambda p: p.state in ('confirmed', 'paid'))"/>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 16px;" border="1">
                            <thead>
                                <tr style="background-color: #003366; color: white;">
                                    <th style="padding: 5px 6px; text-align: center; width: 4%;">#</th>
                                    <th style="padding: 5px 6px; text-align: left; width: 22%;">Employee Name</th>
                                    <th style="padding: 5px 6px; text-align: left; width: 15%;">ID / Passport</th>
                                    <th style="padding: 5px 6px; text-align: left; width: 15%;">Tax Number</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 15%;">Gross Pay (NAD)</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 15%;">Taxable Income</th>
                                    <th style="padding: 5px 6px; text-align: right; width: 14%;">PAYE Deducted</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="active_slips" t-as="slip">
                                    <t t-set="paye_lines" t-value="slip.deduction_line_ids.filtered(lambda l: l.deduction_type == 'paye')"/>
                                    <t t-set="ssc_lines" t-value="slip.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc')"/>
                                    <t t-set="ssc_deduction" t-value="sum(ssc_lines.mapped('amount'))"/>
                                    <t t-set="paye_deduction" t-value="sum(paye_lines.mapped('amount'))"/>
                                    <t t-set="taxable_income" t-value="slip.total_earnings - ssc_deduction"/>
                                    <tr>
                                        <td style="padding: 4px 6px; text-align: center;">
                                            <t t-esc="slip_index + 1"/>
                                        </td>
                                        <td style="padding: 4px 6px;">
                                            <t t-esc="slip.employee_id.name"/>
                                        </td>
                                        <td style="padding: 4px 6px;">
                                            <t t-esc="slip.employee_id.identification_id or '—'"/>
                                        </td>
                                        <td style="padding: 4px 6px;">
                                            <t t-esc="slip.employee_id.security_tax_number or '—'"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % slip.total_earnings"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % taxable_income"/>
                                        </td>
                                        <td style="padding: 4px 6px; text-align: right;">
                                            <t t-esc="'%.2f' % paye_deduction"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color: #e8e8e8; font-weight: bold;">
                                    <td style="padding: 5px 6px; text-align: right;" colspan="4">TOTALS</td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(active_slips.mapped('total_earnings'))"/>
                                    </td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(
                                            (s.total_earnings - sum(s.deduction_line_ids.filtered(lambda l: l.deduction_type == 'ssc').mapped('amount')))
                                            for s in active_slips
                                        )"/>
                                    </td>
                                    <td style="padding: 5px 6px; text-align: right;">
                                        <t t-esc="'%.2f' % sum(
                                            sum(s.deduction_line_ids.filtered(lambda l: l.deduction_type == 'paye').mapped('amount'))
                                            for s in active_slips
                                        )"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Declaration / signature block -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 24px;" border="0">
                            <tr>
                                <td style="width: 50%; padding-right: 16px; vertical-align: top;">
                                    <p style="margin: 0; font-size: 10px; color: #555;">
                                        I, the undersigned, hereby declare that the information contained
                                        in this schedule is true and correct to the best of my knowledge.
                                    </p>
                                    <br/>
                                    <p style="margin: 0;">Authorised Signatory: ________________________</p>
                                    <p style="margin: 4px 0 0 0;">Date: ________________________</p>
                                </td>
                                <td style="width: 50%; padding-left: 16px; vertical-align: top; font-size: 10px; color: #555;">
                                    <p style="margin: 0; font-style: italic;">
                                        This schedule must be submitted to NamRA by the 20th of the
                                        following month together with full payment of all PAYE deducted.<br/>
                                        Ref: Labour Act 11 of 2007 and Income Tax Act 24 of 1981.
                                    </p>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Report action -->
    <record id="action_report_security_paye_submission" model="ir.actions.report">
        <field name="name">NamRA PAYE Tax Schedule</field>
        <field name="model">security.payroll.period</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_l10n_na.report_security_paye_submission_document</field>
        <field name="report_file">security_l10n_na.report_security_paye_submission_document</field>
        <field name="print_report_name">'NamRA_PAYE_%s' % (object.name or 'Schedule')</field>
        <field name="binding_type">report</field>
    </record>

</odoo>
