<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_theme" model="ir.ui.view">
        <field name="name">res.config.settings.view.security.theme</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="DogForce Theme"
                     string="DogForce Theme"
                     name="security_theme"
                     logo="/security_theme/static/src/img/deployguard.png">

                    <block title="UI Theme Preset" name="security_theme_preset">
                        <setting string="Active Theme" help="Applies a color scheme to the backend navigation bar.">
                            <field name="security_active_theme" widget="radio" class="o_light_label"/>
                        </setting>
                    </block>

                    <block title="Typography" name="security_theme_typography">
                        <setting string="UI Font" help="Google Font applied across the backend and login page. Changes take effect on next page load.">
                            <field name="security_ui_font" widget="radio" class="o_light_label"/>
                        </setting>
                    </block>

                    <block title="Login Page" name="security_theme_login">
                        <setting string="Background Color" help="Hex color for the login page background gradient.">
                            <field name="security_login_bg_color"/>
                        </setting>
                        <setting string="Footer Text" help="Text shown at the bottom of the login page.">
                            <field name="security_login_footer"/>
                        </setting>
                    </block>

                    <block title="PDF Report Theming" name="security_theme_reports">
                        <setting string="Report Primary Color"
                                 help="Color injected into PDF report headers, table headings, and footers.">
                            <field name="security_report_primary_color"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
