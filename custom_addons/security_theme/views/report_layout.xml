<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Standalone brand-style block.
        Call via <t t-call="security_theme.report_brand_styles"/> inside any custom
        QWeb report template to inject dynamic brand colors from ir.config_parameter.
        Static brand colors for all Odoo-standard report layouts are delivered via
        report_brand.css in the web.report_assets_pdf bundle.
    -->
    <template id="report_brand_styles" name="DogForce Report Brand Styles">
        <t t-set="brand_color"
           t-value="request.env['ir.config_parameter'].sudo().get_param('security.theme.report_primary_color', '#1e3a5f')"/>
        <style type="text/css">
            .header { border-bottom: 3px solid <t t-out="brand_color"/>; }
            .footer { border-top: 2px solid <t t-out="brand_color"/>; color: #64748b; }
            table thead tr th { background-color: <t t-out="brand_color"/> !important; color: #ffffff !important; }
            h2, h3 { color: <t t-out="brand_color"/>; }
        </style>
    </template>
</odoo>
