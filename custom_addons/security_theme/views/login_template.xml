<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject Google Font into <head> for server-rendered pages (login, frontend) -->
    <template id="theme_font_head" inherit_id="web.layout" name="DogForce Font Loader">
        <xpath expr="//head" position="inside">
            <t t-set="dg_font" t-value="request.env['ir.config_parameter'].sudo().get_param('security.theme.ui_font', 'inter')"/>
            <t t-if="dg_font and dg_font != 'system'">
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
                <t t-if="dg_font == 'inter'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'Inter', system-ui, sans-serif; }</style>
                </t>
                <t t-elif="dg_font == 'plus_jakarta_sans'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }</style>
                </t>
                <t t-elif="dg_font == 'dm_sans'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'DM Sans', system-ui, sans-serif; }</style>
                </t>
                <t t-elif="dg_font == 'nunito'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'Nunito', system-ui, sans-serif; }</style>
                </t>
                <t t-elif="dg_font == 'outfit'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'Outfit', system-ui, sans-serif; }</style>
                </t>
                <t t-elif="dg_font == 'manrope'">
                    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap"/>
                    <style>:root { --dg-font-family: 'Manrope', system-ui, sans-serif; }</style>
                </t>
            </t>
        </xpath>
    </template>

    <!-- Apply branded body class synchronously on first parse — no FOUC -->
    <template id="login_branded" inherit_id="web.login" name="DogForce Login Branding">
        <xpath expr="//div[@id='oe_structure_login_top']" position="before">
            <script>document.body.classList.add('dg_login_branded');</script>
            <div class="dg_login_header text-center mb-3">
                <img src="/security_theme/static/src/img/deployguard-w.png"
                     alt="DeployGuard"
                     style="max-height:56px; width:auto;"/>
                <div class="dg_platform_name fw-bold mt-2" style="font-size:1.15rem; letter-spacing:.03em;">DeployGuard Security Platform</div>
                <div class="dg_platform_tagline text-muted small" style="color:#fff; opacity:0.7;">Professional Security Management Suite</div>
                <div class="dg_login_highlights">
                    <span><i class="fa fa-shield"/> Guard Operations</span>
                    <span><i class="fa fa-calendar-check-o"/> Shift Control</span>
                    <span><i class="fa fa-line-chart"/> Executive Reporting</span>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Override the login layout footer -->
    <template id="login_layout_footer" inherit_id="web.login_layout" name="DogForce Login Footer">
        <xpath expr="//div[hasclass('text-center') and hasclass('small') and hasclass('mt-4')]"
               position="replace">
            <t t-set="login_footer"
               t-value="request.env['ir.config_parameter'].sudo().get_param('security.theme.login_footer', '© 2026 DogForce Security Services. All rights reserved.')"/>
            <div class="dg_login_footer text-center small mt-4 pt-3 border-top">
                <a class="border-end pe-2 me-1" href="/web/database/manager">Manage Databases</a>
                <t t-out="login_footer"/>
            </div>
        </xpath>
    </template>
</odoo>
