<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="security_theme_active_default" model="ir.config_parameter">
            <field name="key">security.theme.active</field>
            <field name="value">dogforce_navy</field>
        </record>
        <record id="security_theme_login_footer_default" model="ir.config_parameter">
            <field name="key">security.theme.login_footer</field>
            <field name="value">© 2026 DogForce Security Services. All rights reserved.</field>
        </record>
        <record id="security_theme_login_bg_color_default" model="ir.config_parameter">
            <field name="key">security.theme.login_bg_color</field>
            <field name="value">#1e3a5f</field>
        </record>
        <record id="security_theme_report_color_default" model="ir.config_parameter">
            <field name="key">security.theme.report_primary_color</field>
            <field name="value">#1e3a5f</field>
        </record>
    </data>
</odoo>
