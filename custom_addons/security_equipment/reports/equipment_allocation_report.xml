<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_equipment_allocation" model="ir.actions.report">
        <field name="name">Equipment Handover Slip</field>
        <field name="model">security.equipment.allocation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_equipment.report_equipment_allocation_template</field>
        <field name="report_file">security_equipment.report_equipment_allocation_template</field>
        <field name="print_report_name">'Equipment_Handover_%s' % (object.name.replace('/', '_'))</field>
        <field name="binding_model_id" ref="model_security_equipment_allocation"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_equipment_allocation_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333;">
                        <!-- Header Banner -->
                        <div class="row mb-4" style="border-bottom: 2px solid #3F51B5; padding-bottom: 12px;">
                            <div class="col-6">
                                <h3 style="color: #3F51B5; font-weight: bold; margin: 0;">DOGFORCE SECURITY SERVICES</h3>
                                <p class="text-muted small" style="margin: 2px 0 0 0;">Namibia Operational Equipment Hub</p>
                            </div>
                            <div class="col-6 text-end">
                                <h4 style="margin: 0; font-weight: bold;"><span t-field="o.name"/></h4>
                                <p class="text-muted small" style="margin: 2px 0 0 0;">Handover Date: <span t-field="o.issue_date"/></p>
                            </div>
                        </div>

                        <!-- Allocation & Employee Details Table -->
                        <h5 class="fw-bold mb-3 text-uppercase" style="font-size: 14px; letter-spacing: 0.5px; color: #555;">Handover Recipient Info</h5>
                        <table class="table table-bordered mb-4" style="border-color: #ddd;">
                            <tbody>
                                <tr>
                                    <th style="background-color: #f9f9f9; width: 25%; font-size: 12px; font-weight: bold;">Security Officer</th>
                                    <td style="font-size: 12px;"><span t-field="o.employee_id.name"/></td>
                                    <th style="background-color: #f9f9f9; width: 25%; font-size: 12px; font-weight: bold;">Employee ID</th>
                                    <td style="font-size: 12px;"><span t-field="o.employee_id.id"/></td>
                                </tr>
                                <tr>
                                    <th style="background-color: #f9f9f9; font-size: 12px; font-weight: bold;">Issued By (Supervisor)</th>
                                    <td style="font-size: 12px;"><span t-field="o.issued_by_id.name"/></td>
                                    <th style="background-color: #f9f9f9; font-size: 12px; font-weight: bold;">Status</th>
                                    <td style="font-size: 12px; font-weight: bold; text-transform: uppercase;"><span t-field="o.state"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Equipment Specifications -->
                        <h5 class="fw-bold mb-3 text-uppercase" style="font-size: 14px; letter-spacing: 0.5px; color: #555;">Equipment Specifications</h5>
                        <table class="table table-bordered mb-4" style="border-color: #ddd;">
                            <thead style="background-color: #f2f2f2; font-size: 12px;">
                                <tr>
                                    <th style="font-weight: bold;">Equipment Profile</th>
                                    <th style="font-weight: bold;">Category</th>
                                    <th style="font-weight: bold; text-align: center;">Serial Number / License</th>
                                    <th style="font-weight: bold; text-align: center;">Condition on Handover</th>
                                    <th style="font-weight: bold; text-align: right;">Quantity</th>
                                </tr>
                            </thead>
                            <tbody style="font-size: 12px;">
                                <tr>
                                    <td><span t-field="o.equipment_type_id.name"/></td>
                                    <td><span t-field="o.equipment_type_id.category_id.name"/></td>
                                    <td style="text-align: center;">
                                        <t t-if="o.is_serialized">
                                            <span t-field="o.equipment_item_id.serial_number"/>
                                            <t t-if="o.equipment_item_id.license_number">
                                                <br/><span class="text-muted small">Lic: <span t-field="o.equipment_item_id.license_number"/></span>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted italic">Non-Serialized</span>
                                        </t>
                                    </td>
                                    <td style="text-align: center; text-transform: uppercase; font-weight: 600;"><span t-field="o.condition_on_issue"/></td>
                                    <td style="text-align: right;"><span t-field="o.quantity"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Conditions / Terms -->
                        <div class="card mb-4" style="border: 1px solid #ddd; background-color: #fafafa; border-radius: 6px;">
                            <div class="card-body p-3" style="font-size: 11px; line-height: 1.4; color: #555;">
                                <h6 class="fw-bold mb-2 text-uppercase" style="font-size: 11px; color: #444;">Legal Liability &amp; Asset Agreement</h6>
                                <p style="margin-bottom: 4px;">1. The Security Officer agrees that the listed assets have been received in the condition specified above.</p>
                                <p style="margin-bottom: 4px;">2. The assets must only be used in execution of official security duties assigned by DogForce.</p>
                                <p style="margin-bottom: 4px;">3. In the event of loss, damage, or theft due to negligence or lack of custody, the Security Officer agrees to a payroll deduction corresponding to the recovery/replacement cost, not exceeding the maximum legal limits.</p>
                                <p style="margin: 0;">4. Serialized firearms must be handled in full accordance with national firearm regulations.</p>
                            </div>
                        </div>

                        <!-- Signatures Box -->
                        <div class="row mt-5" style="padding-top: 30px;">
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid #333; width: 80%; margin: 0 auto; padding-top: 8px;">
                                    <p class="fw-bold small" style="margin: 0;">Security Officer Signature</p>
                                    <p class="text-muted small" style="margin: 0;"><span t-field="o.employee_id.name"/></p>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid #333; width: 80%; margin: 0 auto; padding-top: 8px;">
                                    <p class="fw-bold small" style="margin: 0;">Authorized Handover Supervisor</p>
                                    <p class="text-muted small" style="margin: 0;"><span t-field="o.issued_by_id.name"/></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
