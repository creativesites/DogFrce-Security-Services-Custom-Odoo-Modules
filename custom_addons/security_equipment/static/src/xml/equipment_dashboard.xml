<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="security_equipment.EquipmentDashboard">
<div class="eq-root o_action" style="background:#f0f2f5;min-height:100vh;font-size:0.875rem;">

    <t t-if="state.loading">
        <div style="display:flex;align-items:center;justify-content:center;min-height:300px;gap:12px;color:#6c757d;">
            <div class="spinner-border text-primary"/><span class="fs-5">Loading Equipment Dashboard…</span>
        </div>
    </t>

    <t t-elif="state.data">
        <t t-set="d" t-value="state.data"/>

        <!-- Header -->
        <div style="background:linear-gradient(135deg,#3b1f6e,#1a5e8a);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:12px;">
                <i class="fa fa-shield fa-2x" style="color:rgba(255,255,255,0.9);" title="Equipment"/>
                <div>
                    <h3 style="margin:0;color:white;font-weight:700;">Equipment &amp; Assets</h3>
                    <span style="color:rgba(255,255,255,0.7);font-size:12px;">Allocation overview</span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-light btn-sm" t-on-click="openAllocations">
                    <i class="fa fa-list me-1"/>All Allocations
                </button>
                <button class="btn btn-warning btn-sm" t-on-click="openOverdue" t-if="d.overdue_count > 0">
                    <i class="fa fa-exclamation-triangle me-1"/><t t-esc="d.overdue_count"/> Overdue
                </button>
            </div>
        </div>

        <div class="p-4">
            <!-- KPIs -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-lg-3">
                    <div class="card shadow-sm h-100 text-center">
                        <div class="card-body">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Allocated</div>
                            <div class="fs-1 fw-bold text-primary"><t t-esc="d.allocated"/></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card shadow-sm h-100 text-center">
                        <div class="card-body">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Returned (MTD)</div>
                            <div class="fs-1 fw-bold text-success"><t t-esc="d.returned_mtd"/></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card shadow-sm h-100 text-center" style="cursor:pointer;" t-on-click="openDamages">
                        <div class="card-body">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Damaged / Lost</div>
                            <div t-att-class="'fs-1 fw-bold ' + (d.damaged_lost > 0 ? 'text-warning' : 'text-muted')">
                                <t t-esc="d.damaged_lost"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <div class="card shadow-sm h-100 text-center" style="cursor:pointer;" t-on-click="openOverdue">
                        <div class="card-body">
                            <div class="text-muted small fw-semibold text-uppercase mb-1">Overdue Returns</div>
                            <div t-att-class="'fs-1 fw-bold ' + (d.overdue_count > 0 ? 'text-danger' : 'text-success')">
                                <t t-esc="d.overdue_count"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <!-- By Category -->
                <div class="col-lg-4">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white fw-semibold py-2">
                            <i class="fa fa-tags me-2 text-muted"/>By Category
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Category</th><th class="text-end">Issued</th></tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="d.by_category" t-as="cat" t-key="cat.name">
                                        <tr>
                                            <td><t t-esc="cat.name"/></td>
                                            <td class="text-end fw-semibold"><t t-esc="cat.count"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="d.by_category.length === 0">
                                        <tr><td colspan="2" class="text-center text-muted py-3">No active allocations.</td></tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Overdue Returns -->
                <div class="col-lg-8">
                    <div class="card shadow-sm">
                        <div class="card-header bg-white fw-semibold py-2">
                            <i class="fa fa-exclamation-triangle me-2 text-warning"/>
                            Overdue Returns (<t t-esc="d.overdue_count"/>)
                        </div>
                        <div class="card-body p-0">
                            <t t-if="d.overdue.length === 0">
                                <div class="text-center text-muted py-4">
                                    <i class="fa fa-check-circle fa-2x text-success d-block mb-2" title="All clear"/>
                                    No overdue returns.
                                </div>
                            </t>
                            <t t-else="">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Guard</th>
                                            <th>Equipment</th>
                                            <th>Due Date</th>
                                            <th class="text-end">Days Late</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="d.overdue" t-as="o" t-key="o_index">
                                            <tr>
                                                <td class="fw-semibold"><t t-esc="o.guard"/></td>
                                                <td><t t-esc="o.equipment"/><t t-if="o.item"> — <t t-esc="o.item"/></t></td>
                                                <td class="text-muted small"><t t-esc="o.due_date"/></td>
                                                <td t-att-class="'text-end fw-bold ' + severityColor(o.days_overdue)">
                                                    <t t-esc="o.days_overdue"/>d
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</div>
</t>
</templates>
