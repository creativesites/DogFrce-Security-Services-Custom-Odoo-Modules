    <!-- ================================================================ -->
    <!-- Zambian Public Holidays — 2024                                   -->
    <!-- Source: Public Holidays Act Cap 272 (Zambia); Wikipedia cross-   -->
    <!--         reference. Sunday → Monday substitution per the Act.     -->
    <!-- Saturday holidays are NOT substituted (Act is silent on this).   -->
    <!--                                                                  -->
    <!-- Heroes' Day  = First Monday in July  → Jul 1 (Mon)              -->
    <!-- Unity Day    = Tuesday after Heroes' → Jul 2 (Tue)              -->
    <!-- Farmers' Day = First Monday in Aug   → Aug 5 (Mon)              -->
    <!-- African Freedom Day May 25 = Saturday — no substitution          -->
    <!-- ================================================================ -->
    <record id="security_public_holiday_zm_2024_new_year" model="security.public.holiday">
        <field name="name">New Year's Day</field>
        <field name="country_code">ZM</field>
        <field name="holiday_date">2024-01-01</field>
    </record>
    <record id="security_public_holiday_zm_2024_youth_day" model="security.public.holiday">
        <field name="name">Youth Day</field>
        <field name="country_code">ZM</field>
        <field name="holiday_date">2024-03-12</field>
    </record>
    <record id="security_public_holiday_zm_2024_good_friday" model="security.public.holiday">
        <field name="name">Good Friday</field>
        <field name="country_code">ZM</field>
        <field name="holiday_date">2024-04-19</field>
