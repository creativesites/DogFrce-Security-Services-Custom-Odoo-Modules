        <field name="country_code">ZM</field>
        <field name="holiday_date">2024-05-25</field>
        <field name="note">Falls on Saturday. No Monday substitution under Zambia Public Holidays Act Cap 272 (Sunday-only rule).</field>
    </record>
    <record id="security_public_holiday_zm_2024_heroes_day" model="security.public.holiday">
