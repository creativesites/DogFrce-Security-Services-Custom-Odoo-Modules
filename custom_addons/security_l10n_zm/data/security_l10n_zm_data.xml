<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================ -->
    <!-- Zambia Default Payroll Rule Set                                   -->
    <!-- PAYE brackets: ZRA 2024/2025 (annual thresholds)                 -->
    <!-- NAPSA: 5% employee + 5% employer, ZMW 34,164 ceiling (2025)      -->
    <!-- NHIMA: 0.5% employee + 0.5% employer                             -->
    <!-- VAT: 16% standard rate                                           -->
    <!-- ================================================================ -->
    <record id="security_payroll_rule_set_zm_default" model="security.payroll.rule.set">
        <field name="name">Zambia Default Rule Set</field>
        <field name="country_code">ZM</field>
        <field name="currency_id" ref="base.ZMW"/>
        <field name="effective_from">2025-01-01</field>
        <field name="employee_ssc_rate">0.0</field>
        <field name="employer_ssc_rate">0.0</field>
        <field name="ssc_salary_cap">0.0</field>
        <field name="employee_napsa_rate">0.05</field>
        <field name="employer_napsa_rate">0.05</field>
        <field name="napsa_salary_cap">34164.0</field>
        <field name="employee_nhima_rate">0.005</field>
        <field name="employer_nhima_rate">0.005</field>
        <!-- WCF: 1.75% — mid-range for mixed private security (Class IX, WCFCB).
             Range is 1.25%–2.00%; confirm exact rate annually via eWorkers Portal. -->
        <field name="employer_wcf_rate">0.0175</field>
        <field name="wcf_salary_cap">0.0</field>
        <field name="sunday_multiplier">1.5</field>
        <field name="public_holiday_multiplier">1.5</field>
        <field name="saturday_multiplier">1.25</field>
        <field name="night_shift_multiplier">1.25</field>
        <field name="overtime_multiplier">1.5</field>
        <field name="standard_shift_hours">12</field>
        <field name="vat_rate">16</field>
        <field name="deduction_floor_pct">0.30</field>
        <field name="legal_invoice_text">This invoice is subject to 16% VAT as registered with the Zambia Revenue Authority (ZRA).</field>
    </record>

    <!-- ================================================================ -->
    <!-- Zambia PAYE Tax Brackets — 2024/2025                             -->
    <!-- Source: PwC Tax Summaries (zambia/individual/taxes-on-personal-  -->
    <!--         income); corroborated by Sail Global ZM payroll guide.   -->
    <!-- Note: These are ANNUAL thresholds. The payslip engine converts   -->
    <!--       monthly gross to an annual equivalent before bracket       -->
    <!--       lookup, then divides the resulting tax by 12.              -->
    <!-- ================================================================ -->
    <record id="security_tax_bracket_zm_1" model="security.tax.bracket">
        <field name="rule_set_id" ref="security_l10n_zm.security_payroll_rule_set_zm_default"/>
        <field name="lower_bound">0</field>
        <field name="upper_bound">61200</field>
        <field name="fixed_amount">0</field>
        <field name="rate">0.00</field>
    </record>

    <record id="security_tax_bracket_zm_2" model="security.tax.bracket">
        <field name="rule_set_id" ref="security_l10n_zm.security_payroll_rule_set_zm_default"/>
        <field name="lower_bound">61200.01</field>
        <field name="upper_bound">85200</field>
        <field name="fixed_amount">0</field>
        <field name="rate">0.20</field>
    </record>

    <record id="security_tax_bracket_zm_3" model="security.tax.bracket">
        <field name="rule_set_id" ref="security_l10n_zm.security_payroll_rule_set_zm_default"/>
        <field name="lower_bound">85200.01</field>
        <field name="upper_bound">110400</field>
        <field name="fixed_amount">4800</field>
        <field name="rate">0.30</field>
    </record>

    <record id="security_tax_bracket_zm_4" model="security.tax.bracket">
        <field name="rule_set_id" ref="security_l10n_zm.security_payroll_rule_set_zm_default"/>
        <field name="lower_bound">110400.01</field>
        <field name="upper_bound">999999999</field>
        <field name="fixed_amount">12360</field>
        <field name="rate">0.37</field>
    </record>

