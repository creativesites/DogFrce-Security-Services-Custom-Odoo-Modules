<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_security_loan_statement" model="ir.actions.report">
        <field name="name">Loan Statement</field>
        <field name="model">security.employee.loan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_loans.report_security_loan_statement</field>
        <field name="report_file">security_loans.report_security_loan_statement</field>
        <field name="binding_model_id" ref="model_security_employee_loan"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_security_loan_statement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="loan">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Loan Statement</h2>
                        <table class="table table-sm">
                            <tr><td><strong>Employee</strong></td><td><t t-esc="loan.employee_id.name"/></td></tr>
                            <tr><td><strong>Loan Amount</strong></td><td>N$ <t t-esc="'%.2f' % loan.principal_amount"/></td></tr>
                            <tr><td><strong>Start Date</strong></td><td><t t-esc="loan.start_date"/></td></tr>
                            <tr><td><strong>Monthly Installment</strong></td><td>N$ <t t-esc="'%.2f' % loan.installment_amount"/></td></tr>
                            <tr><td><strong>Total Repayable</strong></td><td>N$ <t t-esc="'%.2f' % loan.total_repayment_amount"/></td></tr>
                            <tr><td><strong>Balance Remaining</strong></td><td>N$ <t t-esc="'%.2f' % loan.balance_remaining"/></td></tr>
                            <tr><td><strong>Status</strong></td><td><t t-esc="loan.state"/></td></tr>
                        </table>

                        <h3>Deduction History</h3>
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Amount (N$)</th>
                                    <th>Payslip</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="loan.deduction_line_ids.sorted('deduction_date')" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.deduction_date"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % line.amount"/></td>
                                        <td><t t-esc="line.payslip_id.name or '—'"/></td>
                                        <td><t t-esc="line.note or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <p class="text-muted small">Generated by DogForce Security Suite</p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
