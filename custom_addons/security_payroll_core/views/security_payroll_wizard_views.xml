<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_payroll_period_wizard_form" model="ir.ui.view">
        <field name="name">security.payroll.period.wizard.form</field>
        <field name="model">security.payroll.period.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Payroll Period">
                <group string="Period Details">
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="rule_set_id"/>
                </group>
                <group string="Eligible Guards">
                    <field name="eligible_employee_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_generate" type="object" string="Generate Payroll Period" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_security_payroll_period_wizard" model="ir.actions.act_window">
        <field name="name">New Payroll Period</field>
        <field name="res_model">security.payroll.period.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
