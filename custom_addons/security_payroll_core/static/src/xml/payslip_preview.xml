<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="security_payroll_core.PayslipPreviewDialog" owl="1">
    <Dialog title="'Payslip Preview'" size="'xl'">
        <t t-set-slot="default">
            <div class="o_payslip_preview_modal" style="height: 75vh; position: relative;">
                <div t-if="state.loading"
                     class="d-flex justify-content-center align-items-center"
                     style="height: 100%;">
                    <div class="text-center text-muted">
                        <i class="fa fa-spinner fa-spin fa-2x mb-2 d-block"/>
                        Loading payslip...
                    </div>
                </div>
                <iframe t-att-src="iframeSrc"
                        t-on-load="onLoad"
                        style="width: 100%; height: 100%; border: none;"
                        t-att-class="state.loading ? 'invisible' : ''"/>
            </div>
        </t>
        <t t-set-slot="footer">
            <button class="pcc-btn pcc-btn-primary" t-on-click="props.close">Close</button>
        </t>
    </Dialog>
</t>

<!-- Minimal empty template for the action wrapper — it only opens a dialog -->
<t t-name="security_payroll_core.PayslipPreviewAction" owl="1">
    <div/>
</t>

</templates>
