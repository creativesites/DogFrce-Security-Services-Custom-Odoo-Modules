<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="security_payroll_core.PayrollCommandCenter">

    <div class="o_payroll_command_center d-flex h-100 overflow-hidden">

        <!-- ===== LEFT SIDEBAR — PERIOD LIST ===== -->
        <div class="o_pcc_sidebar d-flex flex-column"
             style="width:260px; min-width:260px; overflow-y:auto;">

            <div class="px-4 py-4 border-bottom" style="border-color: var(--pcc-border) !important;">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa fa-calendar text-primary"/>
                    <strong class="small text-uppercase text-muted">Payroll Periods</strong>
                </div>
                <div class="small text-muted mt-1">Last 6 periods</div>
            </div>

            <t t-if="state.periods.length === 0">
                <div class="text-center text-muted p-3 small">
                    No payroll periods found.
                </div>
            </t>

            <t t-foreach="state.periods" t-as="period" t-key="period.id">
                <div t-att-class="'o_period_item px-4 py-3 border-bottom d-flex flex-column gap-1 ' + (state.selectedPeriodId === period.id ? 'is-active' : 'text-dark')"
                     t-on-click="() => this.selectPeriod(period.id)"
                     style="cursor:pointer; border-color: var(--pcc-border) !important;">
                    <div class="fw-bold" style="font-size: 14px;">
                        <t t-esc="period.name"/>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mt-2">
                        <span t-att-class="'badge pcc-badge ' + periodStateBadgeClass(period.state)">
                            <t t-esc="period.state"/>
                        </span>
                    </div>
                    <div class="small text-muted fw-semibold mt-2">
                        Net: <t t-esc="formatCurrency(period.total_net_pay)"/>
                    </div>
                </div>
            </t>

        </div>
        <!-- END SIDEBAR -->

        <!-- ===== MAIN CONTENT AREA ===== -->
        <div class="o_pcc_main flex-grow-1 d-flex flex-column overflow-hidden">

            <!-- Header -->
            <div class="o_pcc_header d-flex align-items-center justify-content-between px-5 py-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center justify-content-center bg-primary text-white rounded-3 shadow-sm" style="width: 44px; height: 44px;">
                        <i class="fa fa-money fa-lg"/>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold text-dark" style="letter-spacing: -0.02em;">Payroll Command Center</h4>
                        <div class="text-muted small fw-semibold">
                            <t t-if="selectedPeriod">
                                Period: <t t-esc="selectedPeriod.name"/>
                            </t>
                            <t t-else="">
                                Select a period from the left panel
                            </t>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <t t-if="selectedPeriod">
                        <button class="btn btn-outline-secondary pcc-btn"
                                t-on-click="() => this.openPeriod(state.selectedPeriodId)">
                            <i class="fa fa-external-link me-2"/>Open Period
                        </button>
                    </t>
                </div>
            </div>

            <!-- Loading spinner -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center flex-grow-1">
                    <div class="text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Loading payroll data...</p>
                    </div>
                </div>
            </t>

            <t t-else="">
                <div class="flex-grow-1 d-flex flex-column overflow-auto p-4">

                    <!-- ===== STATS BAR ===== -->
                    <div class="d-flex gap-3 mb-4 flex-wrap">

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill" style="min-width:100px;">
                            <div class="fs-3 fw-bold text-dark mb-1"><t t-esc="state.stats.total"/></div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Total</div>
                        </div>

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill"
                             t-on-click="() => this.setTab('payslips')"
                             style="cursor:pointer; min-width:100px;">
                            <div class="fs-3 fw-bold text-secondary mb-1"><t t-esc="state.stats.draft"/></div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Draft</div>
                        </div>

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill" style="min-width:100px;">
                            <div class="fs-3 fw-bold text-primary mb-1"><t t-esc="state.stats.confirmed"/></div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Confirmed</div>
                        </div>

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill" style="min-width:100px;">
                            <div class="fs-3 fw-bold text-success mb-1"><t t-esc="state.stats.paid"/></div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Paid</div>
                        </div>

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill"
                             t-on-click="() => this.setTab('anomalies')"
                             style="cursor:pointer; min-width:100px;">
                            <div t-att-class="'fs-3 fw-bold mb-1 ' + (state.stats.anomalyCount > 0 ? 'text-warning' : 'text-muted')">
                                <t t-esc="state.stats.anomalyCount"/>
                            </div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Anomalies</div>
                        </div>

                        <div class="pcc-stat-card text-center px-4 py-3 flex-fill" style="min-width:140px; border-bottom: 4px solid var(--pcc-success);">
                            <div class="fs-5 fw-bold text-success mb-1 mt-1">
                                <t t-esc="formatCurrency(state.stats.totalNet)"/>
                            </div>
                            <div class="small fw-bold text-uppercase text-muted" style="letter-spacing:0.05em;">Total Net Pay</div>
                        </div>

                    </div>
                    <!-- END STATS BAR -->

                    <!-- ===== TAB BAR ===== -->
                    <ul class="nav nav-tabs pcc-nav-tabs mb-4 px-1">
                        <li class="nav-item">
                            <button t-att-class="'nav-link' + (state.activeTab === 'overview' ? ' active fw-semibold' : '')"
                                    t-on-click="() => this.setTab('overview')">
                                <i class="fa fa-th-large me-1"/>Overview
                            </button>
                        </li>
                        <li class="nav-item">
                            <button t-att-class="'nav-link' + (state.activeTab === 'payslips' ? ' active fw-semibold' : '')"
                                    t-on-click="() => this.setTab('payslips')">
                                <i class="fa fa-file-text-o me-1"/>Payslips
                                <span class="badge bg-secondary ms-1 small">
                                    <t t-esc="state.stats.total"/>
                                </span>
                            </button>
                        </li>
                        <li class="nav-item">
                            <button t-att-class="'nav-link' + (state.activeTab === 'anomalies' ? ' active fw-semibold' : '') + (state.stats.anomalyCount > 0 ? ' text-warning' : '')"
                                    t-on-click="() => this.setTab('anomalies')">
                                <i class="fa fa-exclamation-triangle me-1"/>Anomalies
                                <t t-if="state.stats.anomalyCount > 0">
                                    <span class="badge bg-warning text-dark ms-1 small">
                                        <t t-esc="state.stats.anomalyCount"/>
                                    </span>
                                </t>
                            </button>
                        </li>
                    </ul>

                    <!-- ===== OVERVIEW TAB ===== -->
                    <t t-if="state.activeTab === 'overview'">
                        <div class="row g-4">

                            <!-- Financial Summary Card -->
                            <div class="col-12 col-md-6">
                                <div class="pcc-card h-100">
                                    <div class="pcc-card-header">
                                        <strong><i class="fa fa-bar-chart me-2 text-primary"/>Period Financial Summary</strong>
                                    </div>
                                    <div class="card-body p-0">
                                        <table class="pcc-table w-100">
                                            <tbody>
                                                <tr>
                                                    <td class="text-muted">Total Gross Earnings</td>
                                                    <td class="text-end fw-semibold text-primary">
                                                        <t t-esc="formatCurrency(state.stats.totalGross)"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Total Deductions</td>
                                                    <td class="text-end fw-semibold text-danger">
                                                        (<t t-esc="formatCurrency(state.stats.totalDeductions)"/>)
                                                    </td>
                                                </tr>
                                                <tr class="table-success">
                                                    <td class="fw-bold">Net Pay (Total)</td>
                                                    <td class="text-end fw-bold text-success">
                                                        <t t-esc="formatCurrency(state.stats.totalNet)"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Action Buttons Card -->
                            <div class="col-12 col-md-6">
                                <div class="pcc-card h-100">
                                    <div class="pcc-card-header">
                                        <strong><i class="fa fa-bolt me-2 text-warning"/>Bulk Actions</strong>
                                    </div>
                                    <div class="card-body d-flex flex-column gap-3 p-4">

                                        <div>
                                            <button class="btn btn-primary w-100 d-flex align-items-center justify-content-between pcc-btn"
                                                    t-on-click="bulkConfirm"
                                                    t-att-disabled="state.stats.draft === 0 || !state.selectedPeriodId">
                                                <span>
                                                    <i class="fa fa-check me-2"/>Confirm All Drafts
                                                </span>
                                                <span class="badge bg-white text-primary">
                                                    <t t-esc="state.stats.draft"/>
                                                </span>
                                            </button>
                                            <div class="small text-muted mt-1 px-1">
                                                Moves all draft payslips to confirmed state.
                                            </div>
                                        </div>

                                        <div>
                                            <button class="btn btn-success w-100 d-flex align-items-center justify-content-between pcc-btn"
                                                    t-on-click="bulkMarkPaid"
                                                    t-att-disabled="state.stats.confirmed === 0 || !state.selectedPeriodId">
                                                <span>
                                                    <i class="fa fa-money me-2"/>Mark All Confirmed as Paid
                                                </span>
                                                <span class="badge bg-white text-success">
                                                    <t t-esc="state.stats.confirmed"/>
                                                </span>
                                            </button>
                                            <div class="small text-muted mt-1 px-1">
                                                Marks all confirmed payslips as paid.
                                            </div>
                                        </div>

                                        <div>
                                            <button class="btn btn-outline-secondary w-100 pcc-btn"
                                                    t-on-click="() => this.openPeriod(state.selectedPeriodId)"
                                                    t-att-disabled="!state.selectedPeriodId">
                                                <i class="fa fa-print me-2"/>Open Period for Batch Print
                                            </button>
                                            <div class="small text-muted mt-1 px-1">
                                                Open the period form to print a payslip batch report.
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>

                            <!-- Status Breakdown -->
                            <div class="col-12">
                                <div class="pcc-card">
                                    <div class="pcc-card-header">
                                        <strong><i class="fa fa-pie-chart me-2 text-info"/>Payslip Status Breakdown</strong>
                                    </div>
                                    <div class="card-body p-0">
                                        <table class="pcc-table w-100 mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Status</th>
                                                    <th class="text-end">Count</th>
                                                    <th class="text-end">% of Total</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td><span class="badge bg-secondary me-2">Draft</span>Draft</td>
                                                    <td class="text-end"><t t-esc="state.stats.draft"/></td>
                                                    <td class="text-end">
                                                        <t t-esc="state.stats.total > 0 ? ((state.stats.draft / state.stats.total) * 100).toFixed(1) + '%' : '—'"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span class="badge bg-primary me-2">Confirmed</span>Confirmed</td>
                                                    <td class="text-end"><t t-esc="state.stats.confirmed"/></td>
                                                    <td class="text-end">
                                                        <t t-esc="state.stats.total > 0 ? ((state.stats.confirmed / state.stats.total) * 100).toFixed(1) + '%' : '—'"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span class="badge bg-success me-2">Paid</span>Paid</td>
                                                    <td class="text-end"><t t-esc="state.stats.paid"/></td>
                                                    <td class="text-end">
                                                        <t t-esc="state.stats.total > 0 ? ((state.stats.paid / state.stats.total) * 100).toFixed(1) + '%' : '—'"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                            <tfoot class="fw-bold" style="background: var(--pcc-surface-soft);">
                                                <tr>
                                                    <td>Total</td>
                                                    <td class="text-end"><t t-esc="state.stats.total"/></td>
                                                    <td class="text-end">100%</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                    <!-- END OVERVIEW TAB -->

                    <!-- ===== PAYSLIPS TAB ===== -->
                    <t t-if="state.activeTab === 'payslips'">
                        <div class="pcc-card">
                            <div class="pcc-card-header d-flex align-items-center justify-content-between">
                                <strong><i class="fa fa-file-text-o me-2 text-primary"/>All Payslips</strong>
                                <span class="text-muted small">
                                    <t t-esc="state.payslips.length"/> payslip(s)
                                </span>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="state.payslips.length === 0">
                                    <div class="text-center text-muted p-5">
                                        <i class="fa fa-file-o fa-3x mb-3 d-block"/>
                                        No payslips found for this period. Generate payslips from the period form.
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="table-responsive">
                                        <table class="pcc-table w-100 mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Employee</th>
                                                    <th class="text-center">Days</th>
                                                    <th class="text-center">Status</th>
                                                    <th class="text-end">Gross</th>
                                                    <th class="text-end">Deductions</th>
                                                    <th class="text-end">Net Pay</th>
                                                    <th class="text-center">Anomaly</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="state.payslips" t-as="ps" t-key="ps.id">
                                                    <tr t-att-class="(ps.anomaly_score || 0) > 0 ? 'table-warning' : ''"
                                                        t-on-click="() => this.openPayslip(ps.id)"
                                                        style="cursor:pointer;">
                                                        <td class="fw-semibold text-primary small">
                                                            <t t-esc="ps.name"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="ps.employee_id and ps.employee_id[1] or '—'"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <t t-esc="ps.worked_days || 0"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <span t-att-class="'badge small ' + stateBadgeClass(ps.state)">
                                                                <t t-esc="ps.state"/>
                                                            </span>
                                                        </td>
                                                        <td class="text-end small">
                                                            <t t-esc="formatCurrency(ps.total_earnings)"/>
                                                        </td>
                                                        <td class="text-end small text-danger">
                                                            (<t t-esc="formatCurrency(ps.total_deductions)"/>)
                                                        </td>
                                                        <td class="text-end small fw-semibold">
                                                            <t t-esc="formatCurrency(ps.net_pay)"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <t t-if="(ps.anomaly_score || 0) > 0">
                                                                <span class="badge bg-warning text-dark">
                                                                    <i class="fa fa-exclamation-triangle me-1"/>
                                                                    <t t-esc="ps.anomaly_score"/>
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="text-muted small">—</span>
                                                            </t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                            <tfoot class="fw-bold" style="background: var(--pcc-surface-soft);">
                                                <tr>
                                                    <td colspan="4">Totals</td>
                                                    <td class="text-end small">
                                                        <t t-esc="formatCurrency(state.stats.totalGross)"/>
                                                    </td>
                                                    <td class="text-end small text-danger">
                                                        (<t t-esc="formatCurrency(state.stats.totalDeductions)"/>)
                                                    </td>
                                                    <td class="text-end small text-success">
                                                        <t t-esc="formatCurrency(state.stats.totalNet)"/>
                                                    </td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                    <!-- END PAYSLIPS TAB -->

                    <!-- ===== ANOMALIES TAB ===== -->
                    <t t-if="state.activeTab === 'anomalies'">
                        <div class="pcc-card">
                            <div class="pcc-card-header d-flex align-items-center justify-content-between">
                                <strong>
                                    <i class="fa fa-exclamation-triangle text-warning me-2"/>
                                    Payslips with Anomalies
                                </strong>
                                <span class="badge bg-warning text-dark">
                                    <t t-esc="anomalyPayslips.length"/> flagged
                                </span>
                            </div>
                            <div class="card-body p-0">
                                <t t-if="anomalyPayslips.length === 0">
                                    <div class="text-center text-muted p-5">
                                        <i class="fa fa-check-circle fa-3x text-success mb-3 d-block"/>
                                        No anomalies detected in this period. All payslips look clean.
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="alert alert-warning m-3">
                                        <i class="fa fa-info-circle me-2"/>
                                        The following payslips have anomaly scores greater than zero.
                                        Review each payslip carefully before confirming or paying.
                                    </div>
                                    <div class="table-responsive">
                                        <table class="pcc-table w-100 mb-0">
                                            <thead style="background: #fffbeb;">
                                                <tr>
                                                    <th>Reference</th>
                                                    <th>Employee</th>
                                                    <th class="text-center">Status</th>
                                                    <th class="text-center">Score</th>
                                                    <th>Anomaly Flags</th>
                                                    <th class="text-end">Net Pay</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="anomalyPayslips" t-as="ps" t-key="ps.id">
                                                    <tr class="table-warning"
                                                        t-on-click="() => this.openPayslip(ps.id)"
                                                        style="cursor:pointer;">
                                                        <td class="fw-semibold text-primary small">
                                                            <t t-esc="ps.name"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="ps.employee_id and ps.employee_id[1] or '—'"/>
                                                        </td>
                                                        <td class="text-center">
                                                            <span t-att-class="'badge small ' + stateBadgeClass(ps.state)">
                                                                <t t-esc="ps.state"/>
                                                            </span>
                                                        </td>
                                                        <td class="text-center">
                                                            <span class="badge bg-danger">
                                                                <t t-esc="ps.anomaly_score"/>
                                                            </span>
                                                        </td>
                                                        <td class="small text-muted" style="max-width:300px; word-break:break-word;">
                                                            <t t-esc="ps.anomaly_flags or 'No details recorded'"/>
                                                        </td>
                                                        <td class="text-end small fw-semibold">
                                                            <t t-esc="formatCurrency(ps.net_pay)"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                    <!-- END ANOMALIES TAB -->

                </div>
            </t>
            <!-- END MAIN CONTENT -->

        </div>
        <!-- END MAIN AREA -->

    </div>
</t>

</templates>
