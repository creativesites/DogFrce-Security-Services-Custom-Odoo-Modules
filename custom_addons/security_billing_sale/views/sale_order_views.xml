<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Smart button and Action button on sale.order form view -->
    <record id="view_order_form_inherit_security_billing" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.security.billing</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_security_billing_plan"
                        string="Create Billing Plan"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('sale', 'done')"
                        groups="security_base.group_security_supervisor"/>
                <button name="action_create_security_contract"
                        string="Create Client Contract"
                        type="object"
                        class="btn-secondary"
                        invisible="state not in ('sale', 'done')"
                        groups="security_base.group_security_supervisor"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_billing_plans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-usd"
                        groups="security_base.group_security_supervisor">
                    <field name="billing_plan_count" widget="statinfo" string="Billing Plans"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="billing_plan_ids" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- Smart field on security.billing.plan form view -->
    <record id="view_security_billing_plan_form_inherit_sale" model="ir.ui.view">
        <field name="name">security.billing.plan.form.inherit.sale</field>
        <field name="model">security.billing.plan</field>
        <field name="inherit_id" ref="security_billing.view_security_billing_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="sale_order_id" groups="security_base.group_security_supervisor" readonly="1" invisible="not sale_order_id"/>
            </xpath>
        </field>
    </record>
</odoo>
