<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_security_client_service" model="ir.actions.report">
        <field name="name">Client Service Report</field>
        <field name="model">security.client.service.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_client_reports.report_security_client_service</field>
        <field name="report_file">security_client_reports.report_security_client_service</field>
        <field name="binding_model_id" ref="model_security_client_service_report"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_security_client_service">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Branding Header -->
                        <div style="border-bottom: 2px solid #2c3e50; margin-bottom: 16px; padding-bottom: 8px;">
                            <table width="100%">
                                <tr>
                                    <td style="vertical-align: middle;">
                                        <h1 style="margin: 0; color: #2c3e50; font-size: 22px;">DogForce Security Services</h1>
                                        <p style="margin: 2px 0 0 0; color: #7f8c8d; font-size: 11px;">Professional Security Solutions</p>
                                    </td>
                                    <td style="text-align: right; vertical-align: middle;">
                                        <h2 style="margin: 0; color: #2c3e50; font-size: 16px; text-transform: uppercase; letter-spacing: 1px;">Client Service Report</h2>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Report Meta Table -->
                        <table class="table table-sm" style="margin-bottom: 20px; font-size: 12px;">
                            <tbody>
                                <tr>
                                    <td style="width: 20%; font-weight: bold; background-color: #f8f9fa;">Client</td>
                                    <td style="width: 30%;"><span t-field="doc.partner_id"/></td>
                                    <td style="width: 20%; font-weight: bold; background-color: #f8f9fa;">Prepared By</td>
                                    <td style="width: 30%;"><span t-field="doc.prepared_by_id"/></td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f8f9fa;">Site</td>
                                    <td><t t-if="doc.site_id"><span t-field="doc.site_id"/></t><t t-else="">All Sites</t></td>
                                    <td style="font-weight: bold; background-color: #f8f9fa;">Date Generated</td>
                                    <td><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y %H:%M')"/></td>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; background-color: #f8f9fa;">Period</td>
                                    <td colspan="3">
                                        <span t-field="doc.date_from"/> to <span t-field="doc.date_to"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Summary Metrics -->
                        <h3 style="color: #2c3e50; font-size: 13px; text-transform: uppercase; border-bottom: 1px solid #bdc3c7; padding-bottom: 4px; margin-bottom: 8px;">Summary</h3>
                        <table class="table table-sm o_main_table" style="margin-bottom: 20px; font-size: 12px;">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th>Metric</th>
                                    <th class="text-end">Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Scheduled Shifts</td>
                                    <td class="text-end"><span t-field="doc.scheduled_shift_count"/></td>
                                </tr>
                                <tr>
                                    <td>Attended Shifts</td>
                                    <td class="text-end"><span t-field="doc.attended_shift_count"/></td>
                                </tr>
                                <tr>
                                    <td>Absent Shifts</td>
                                    <td class="text-end"><span t-field="doc.absent_shift_count"/></td>
                                </tr>
                                <tr>
                                    <td>AWOL Count</td>
                                    <td class="text-end"><span t-field="doc.awol_count"/></td>
                                </tr>
                                <tr style="background-color: #f8f9fa;">
                                    <td><strong>Attendance Rate (%)</strong></td>
                                    <td class="text-end">
                                        <strong>
                                            <t t-if="doc.scheduled_shift_count">
                                                <t t-esc="'%.1f' % (doc.attended_shift_count / doc.scheduled_shift_count * 100)"/>%
                                            </t>
                                            <t t-else="">N/A</t>
                                        </strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Total Scheduled Hours</td>
                                    <td class="text-end"><span t-field="doc.total_scheduled_hours"/></td>
                                </tr>
                                <tr>
                                    <td>Total Payable Hours</td>
                                    <td class="text-end"><span t-field="doc.total_payable_hours"/></td>
                                </tr>
                                <tr>
                                    <td>Total Unpaid Hours</td>
                                    <td class="text-end"><span t-field="doc.total_unpaid_hours"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Attendance Detail Table (only if include_guard_names) -->
                        <t t-if="doc.include_guard_names">
                            <h3 style="color: #2c3e50; font-size: 13px; text-transform: uppercase; border-bottom: 1px solid #bdc3c7; padding-bottom: 4px; margin-bottom: 8px;">Attendance Details</h3>
                            <table class="table table-sm o_main_table" style="font-size: 11px;">
                                <thead>
                                    <tr style="background-color: #2c3e50; color: white;">
                                        <th>Date</th>
                                        <th>Guard Name</th>
                                        <th>Post</th>
                                        <th>Shift</th>
                                        <th>Status</th>
                                        <th class="text-end">Hours</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.attendance_record_ids.sorted('shift_date')" t-as="line">
                                        <td><span t-field="line.shift_date"/></td>
                                        <td><span t-field="line.employee_id"/></td>
                                        <td><span t-field="line.post_id"/></td>
                                        <td><span t-field="line.shift_template_id"/></td>
                                        <td><span t-field="line.status"/></td>
                                        <td class="text-end"><span t-field="line.payable_hours"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                        <t t-else="">
                            <h3 style="color: #2c3e50; font-size: 13px; text-transform: uppercase; border-bottom: 1px solid #bdc3c7; padding-bottom: 4px; margin-bottom: 8px;">Attendance Details</h3>
                            <table class="table table-sm o_main_table" style="font-size: 11px;">
                                <thead>
                                    <tr style="background-color: #2c3e50; color: white;">
                                        <th>Date</th>
                                        <th>Post</th>
                                        <th>Shift</th>
                                        <th>Status</th>
                                        <th class="text-end">Hours</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.attendance_record_ids.sorted('shift_date')" t-as="line">
                                        <td><span t-field="line.shift_date"/></td>
                                        <td><span t-field="line.post_id"/></td>
                                        <td><span t-field="line.shift_template_id"/></td>
                                        <td><span t-field="line.status"/></td>
                                        <td class="text-end"><span t-field="line.payable_hours"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>

                        <!-- Footer -->
                        <div style="margin-top: 30px; border-top: 1px solid #bdc3c7; padding-top: 8px; text-align: center; color: #7f8c8d; font-size: 10px;">
                            This report is confidential — DogForce Security Services
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
