<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════════
         Client Onboarding Wizard — 6-step form
    ════════════════════════════════════════════════════════════════════ -->

    <record id="view_security_client_onboarding_wizard_form" model="ir.ui.view">
        <field name="name">security.client.onboarding.wizard.form</field>
        <field name="model">security.client.onboarding.wizard</field>
        <field name="arch" type="xml">
            <form string="New Client Onboarding">
                <sheet>
                    <!-- Step progress bar (statusbar widget — no OWL template needed) -->
                    <field name="step" widget="statusbar"
                           statusbar_visible="1_client,2_sites,3_requirements,4_billing,5_roster,6_confirm"
                           readonly="1"/>

                    <!-- ── Step 1: Client &amp; Contract ── -->
                    <group invisible="step != '1_client'">
                        <group string="Select Existing Client">
                            <field name="existing_partner_id" placeholder="Search existing clients…"/>
                        </group>
                        <group string="Or Create New Client">
                            <field name="new_partner_name" placeholder="Company / Client Name"
                                   invisible="existing_partner_id != False"/>
                            <field name="new_partner_email" invisible="existing_partner_id != False"/>
                            <field name="new_partner_phone" invisible="existing_partner_id != False"/>
                            <field name="new_partner_street" invisible="existing_partner_id != False"/>
                        </group>
                        <group string="Contract">
                            <field name="contract_start"/>
                        </group>
                    </group>

                    <!-- ── Step 2: Sites ── -->
                    <group invisible="step != '2_sites'">
                        <div class="text-muted small mb-2" colspan="2">
                            Add one or more deployment sites for this client.
                        </div>
                        <field name="site_line_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="site_name" placeholder="e.g. Head Office"/>
                                <field name="code" placeholder="e.g. HQ"/>
                                <field name="location" placeholder="Physical address"/>
                            </list>
                        </field>
                    </group>

                    <!-- ── Step 3: Shift Requirements ── -->
                    <group invisible="step != '3_requirements'">
                        <div class="text-muted small mb-2" colspan="2">
                            Define shift requirements. The <em>Site</em> column must match a site name from Step 2 exactly (leave blank to use the first site).
                        </div>
                        <field name="requirement_line_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="site_name" placeholder="Match site name from Step 2"/>
                                <field name="post_id"/>
                                <field name="shift_template_id"/>
                                <field name="guard_count"/>
                                <field name="bill_rate" string="Bill Rate (N$)"/>
                                <field name="pay_rate" string="Pay Rate (N$)"/>
                            </list>
                        </field>
                    </group>

                    <!-- ── Step 4: Billing Plan ── -->
                    <group invisible="step != '4_billing'" string="Billing Plan">
                        <field name="billing_mode"/>
                        <field name="billing_start"/>
                        <field name="billing_payment_term_days"/>
                        <field name="billing_vat_rate"/>
                    </group>

                    <!-- ── Step 5: First Roster ── -->
                    <group invisible="step != '5_roster'" string="First Roster Batch">
                        <field name="generate_first_roster"/>
                        <field name="roster_month" invisible="not generate_first_roster"
                               help="Roster slots will be generated for this month based on shift requirements from Step 3."/>
                    </group>

                    <!-- ── Step 6: Confirm ── -->
                    <group invisible="step != '6_confirm'">
                        <div class="text-muted small mb-3" colspan="2">
                            Review the summary below and click <strong>Create Client</strong> to create all records atomically.
                        </div>
                        <field name="summary_html" nolabel="1" widget="html" readonly="1" colspan="2"/>
                    </group>

                </sheet>

                <footer>
                    <button name="action_back" type="object" string="← Back"
                            class="btn-secondary"
                            invisible="step == '1_client'"/>
                    <button name="action_next" type="object" string="Next →"
                            class="btn-primary"
                            invisible="step == '6_confirm'"/>
                    <button name="action_confirm" type="object" string="Create Client"
                            class="btn-success"
                            invisible="step != '6_confirm'"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Roster Setup Health Check Wizard
    ════════════════════════════════════════════════════════════════════ -->

    <record id="view_security_roster_setup_wizard_form" model="ir.ui.view">
        <field name="name">security.roster.setup.wizard.form</field>
        <field name="model">security.roster.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="Roster Setup Health Check">
                <sheet>
                    <div class="alert alert-info mb-3" role="status" invisible="issue_ids != []">
                        <i class="fa fa-check-circle me-2" title="All clear"/>
                        <strong>All checks passed.</strong> Your roster configuration looks healthy.
                    </div>
                    <div class="alert alert-warning mb-3" role="alert" invisible="issue_ids == []">
                        <i class="fa fa-exclamation-triangle me-2" title="Issues found"/>
                        <strong><field name="issue_count" nolabel="1" readonly="1"/> issue(s) found.</strong>
                        Review and resolve each item below.
                    </div>

                    <field name="issue_ids" nolabel="1" readonly="1">
                        <list decoration-danger="severity == 'critical'"
                              decoration-warning="severity == 'warning'">
                            <field name="severity" widget="badge"
                                   decoration-danger="severity == 'critical'"
                                   decoration-warning="severity == 'warning'"/>
                            <field name="category" string="Area"/>
                            <field name="title" string="Issue"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_run_check" type="object" string="Run Check"
                            class="btn-primary"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Actions -->

    <record id="action_security_client_onboarding_wizard" model="ir.actions.act_window">
        <field name="name">Onboard New Client</field>
        <field name="res_model">security.client.onboarding.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_security_roster_setup_wizard" model="ir.actions.act_window">
        <field name="name">Roster Setup Health Check</field>
        <field name="res_model">security.roster.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_run_on_open': True}</field>
    </record>

    <!-- Menu items (Operations > Roster section & Clients & Sites section) -->

    <record id="action_security_client_partner" model="ir.actions.act_window">
        <field name="name">Client Companies</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_company', '=', True)]</field>
        <field name="context">{'default_is_company': True, 'default_customer_rank': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a Client Company!
            </p>
            <p>
                Manage client profiles, contact persons, sites, contracts, and billing plans.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_security_client_partner"
        name="Client Companies"
        parent="security_operations.menu_security_billing_root"
        action="action_security_client_partner"
        sequence="1"
        groups="hr.group_hr_user,security_base.group_security_supervisor"
    />

    <menuitem
        id="menu_security_client_onboarding"
        name="Client Setup &amp; Onboarding"
        parent="security_operations.menu_security_billing_root"
        action="action_security_client_onboarding_wizard"
        sequence="2"
        groups="hr.group_hr_user,security_base.group_security_supervisor"
    />

    <menuitem
        id="menu_security_client_onboarding_ops"
        name="Onboard New Client"
        parent="security_operations.menu_security_roster"
        action="action_security_client_onboarding_wizard"
        sequence="5"
        groups="hr.group_hr_user,security_base.group_security_supervisor"
    />

    <menuitem
        id="menu_security_roster_setup_check"
        name="Roster Setup Check"
        parent="security_operations.menu_security_roster"
        action="action_security_roster_setup_wizard"
        sequence="6"
        groups="hr.group_hr_user,security_base.group_security_supervisor"
    />

</odoo>
