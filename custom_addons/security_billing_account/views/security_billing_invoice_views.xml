<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Odoo Invoice View Action Button on custom security.billing.invoice form -->
    <record id="view_security_billing_invoice_form_inherit_account" model="ir.ui.view">
        <name>security.billing.invoice.form.inherit.account</name>
        <model>security.billing.invoice</model>
        <inherit_id ref="security_billing.view_security_billing_invoice_form"/>
        <arch type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_view_odoo_invoice"
                        string="View Odoo Invoice"
                        type="object"
                        class="btn-secondary"
                        invisible="state == 'draft'"
                        groups="security_base.group_security_supervisor"/>
            </xpath>
            <xpath expr="//field[@name='generation_source']" position="after">
                <field name="move_id" groups="security_base.group_security_supervisor" readonly="1" invisible="not move_id"/>
            </xpath>
        </arch>
    </record>
</odoo>
