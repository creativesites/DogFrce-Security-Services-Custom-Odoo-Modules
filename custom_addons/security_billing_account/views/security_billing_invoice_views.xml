<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Odoo Invoice View Action Button & Auto-Reconcile Button on custom security.billing.invoice form -->
    <record id="view_security_billing_invoice_form_inherit_account" model="ir.ui.view">
        <field name="name">security.billing.invoice.form.inherit.account</field>
        <field name="model">security.billing.invoice</field>
        <field name="inherit_id" ref="security_billing.view_security_billing_invoice_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_view_odoo_invoice"
                        string="View Odoo Invoice"
                        type="object"
                        class="btn-secondary"
                        invisible="state == 'draft'"
                        groups="security_base.group_security_supervisor"/>
                <button name="action_auto_reconcile"
                        string="Auto-Reconcile"
                        type="object"
                        class="btn-secondary"
                        invisible="state == 'draft'"
                        groups="security_base.group_security_supervisor"/>
            </xpath>
            <xpath expr="//field[@name='generation_source']" position="after">
                <field name="move_id" groups="security_base.group_security_supervisor" readonly="1" invisible="not move_id"/>
            </xpath>
        </field>
    </record>

    <!-- Server Action for Multi Auto-Reconcile in List Views -->
    <record id="action_server_reconcile_invoices" model="ir.actions.server">
        <field name="name">Auto-Reconcile Invoices</field>
        <field name="model_id" ref="security_billing.model_security_billing_invoice"/>
        <field name="binding_model_id" ref="security_billing.model_security_billing_invoice"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_auto_reconcile()
        </field>
    </record>
</odoo>
